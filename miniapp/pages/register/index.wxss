.register-page {
  background: #fafaf8;
}

.register-hero {
  background: linear-gradient(135deg, #ffffff 0%, #f4f7e6 100%);
  border-color: rgba(184, 208, 96, 0.22);
}

.register-phone-hint {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.register-phone-value {
  color: var(--brand-dark);
  font-weight: 700;
}

.register-actions {
  padding: 0 8rpx;
}

.register-login-link {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--brand-dark);
}
