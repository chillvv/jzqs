.service-hero {
  margin: -40rpx 24rpx 20rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, #f7f9ee 100%);
  box-shadow: 0 10rpx 28rpx rgba(146, 170, 64, 0.12);
  position: relative;
  z-index: 3;
}

.service-hero__eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--brand-dark);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.service-hero__title {
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: var(--text-main);
  line-height: 1.35;
}

.service-hero__desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

.service-pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.service-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  border: 2rpx solid rgba(146, 170, 64, 0.2);
  color: var(--brand-dark);
  font-size: 22rpx;
  font-weight: 700;
}

.service-hero__cta {
  margin-top: 24rpx;
  width: 100%;
  border: none;
  border-radius: 999rpx;
  background: var(--brand-primary);
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.service-hero__cta::after {
  border: none;
}

.service-guide-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: var(--bg-card);
  box-shadow: var(--shadow-sm);
}

.service-guide-card__title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main);
}

.service-guide-card__item {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  align-items: flex-start;
}

.service-guide-card__index {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--brand-light);
  color: var(--brand-dark);
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.service-guide-card__text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

/* =========================================
   全屏强制公告
   ========================================= */
.fullscreen-announcement {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: linear-gradient(160deg, #f7f9ee 0%, #e8f0d0 40%, #dce6c0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx 40rpx 120rpx;
  box-sizing: border-box;
}

.fullscreen-announcement__content {
  width: 100%;
  max-width: 620rpx;
  text-align: center;
}

.fullscreen-announcement__badge {
  display: inline-block;
  padding: 8rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(146, 170, 64, 0.18);
  color: var(--brand-dark);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.fullscreen-announcement__title {
  margin-top: 32rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: #2d3a1a;
  line-height: 1.3;
}

.fullscreen-announcement__body {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.fullscreen-announcement__line {
  font-size: 28rpx;
  line-height: 1.75;
  color: #4a5a2e;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 16rpx;
}

.fullscreen-announcement__hint {
  margin-top: 56rpx;
  font-size: 22rpx;
  color: var(--brand-dark);
  opacity: 0.7;
  letter-spacing: 1rpx;
}

.meal-reminder-popup {
  position: fixed;
  inset: 0;
  z-index: 9999;
}

.meal-reminder-popup__mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.46);
  backdrop-filter: blur(8rpx);
}

.meal-reminder-popup__panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 40rpx 32rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #fffdf6 0%, var(--bg-card) 52%, #f8fbef 100%);
  box-shadow: 0 30rpx 80rpx rgba(31, 41, 55, 0.18);
}

.meal-reminder-popup__badge {
  display: inline-flex;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(146, 170, 64, 0.14);
  color: #7f9533;
  font-size: 22rpx;
  font-weight: 700;
}

.meal-reminder-popup__title {
  margin-top: 24rpx;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.35;
  color: #1f2937;
}

.meal-reminder-popup__message {
  margin-top: 20rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #4b5563;
}

.meal-reminder-popup__check {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #556274;
  font-size: 24rpx;
}

.meal-reminder-popup__checkbox {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  border: 2rpx solid rgba(146, 170, 64, 0.4);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: transparent;
  background: var(--bg-card);
  font-size: 22rpx;
  font-weight: 700;
}

.meal-reminder-popup__checkbox.is-checked {
  background: var(--brand-dark);
  border-color: var(--brand-dark);
  color: #ffffff;
}

.meal-reminder-popup__button {
  margin-top: 32rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #cfe37a 0%, var(--brand-primary) 100%);
  color: #243018;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.meal-reminder-popup__button::after {
  border: none;
}

/* =========================================
   轮播图指示器美化
   ========================================= */
.hero-swiper .wx-swiper-dots {
  bottom: 80rpx !important;
}

.hero-swiper .wx-swiper-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 6rpx;
  margin: 0 8rpx;
  background: rgba(255, 255, 255, 0.5);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.hero-swiper .wx-swiper-dot-active {
  width: 32rpx;
  border-radius: 6rpx;
  background: var(--bg-card);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* =========================================
   Tab 1：首页（从 app.wxss 拆入）
   ========================================= */
#tab-home { background: var(--bg-card-alt); min-height: 100vh; padding-bottom: calc(136rpx + env(safe-area-inset-bottom)); }

.hero-banner {
  width: 100%; height: 500rpx;
  position: relative;
  transition: height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
  background: linear-gradient(180deg, #eef2e2 0%, #f7f8f2 100%);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}
.hero-banner.expanded {
  height: 560rpx;
}
.hero-swiper { width: 100%; height: 100%; }
.hero-banner-card { position: relative; width: 100%; height: 100%; }
.hero-banner-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  transition: all 0.3s ease;
}

.menu-top-row { display: flex; align-items: center; gap: 16rpx; margin-top: 8rpx; }
.date-tag { background: #f0f4e8; color: var(--brand-color); font-size: 24rpx; font-weight: 700; padding: 4rpx 16rpx; border-radius: 8rpx; }
.detail-icon { font-size: 20rpx; margin-left: 8rpx; color: rgba(0,0,0,0.3); }
.highlight-card { border: 2rpx solid var(--brand-color) !important; box-shadow: 0 4rpx 20rpx rgba(184, 208, 96, 0.2) !important; }
.edit-icon { font-size: 24rpx; margin-left: 8rpx; color: rgba(255,255,255,0.7); }
.logout-section { padding: 40rpx; margin-top: 20rpx; }
.btn-logout { width: 100% !important; box-sizing: border-box; background: var(--bg-card); color: #ff4d4f; border: 1rpx solid #ff4d4f; border-radius: 40rpx; font-size: 28rpx; height: 88rpx; display: flex; justify-content: center; align-items: center; text-align: center; padding: 0; margin: 0; }
.related-order-hint { margin-top: 16rpx; font-size: 24rpx; color: var(--brand-color); font-weight: 600; display: flex; align-items: center; }
.related-order-hint .arrow { margin-left: 4rpx; }

.menu-section { position: relative; margin-top: 24rpx; z-index: 2; padding-bottom: 40rpx; }
.poster-header { padding: 0 32rpx 24rpx; display: flex; justify-content: space-between; align-items: flex-end; }
.poster-title { font-size: 44rpx; font-weight: 800; color: var(--text-main); letter-spacing: 2rpx; }
.poster-subtitle { font-size: 22rpx; color: var(--brand-dark); font-weight: 700; letter-spacing: 3rpx; text-transform: uppercase; margin-bottom: 8rpx; }
.poster-range { font-size: 24rpx; color: var(--text-sub); font-weight: 600; padding-bottom: 4rpx; }
.menu-list { display: flex; flex-direction: column; gap: 32rpx; padding: 0 32rpx; }

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.day-card-full { background: var(--bg-card); border-radius: 32rpx; box-shadow: var(--shadow-sm); border: 2rpx solid var(--border); overflow: hidden; transform: translateZ(0); animation: fadeInUp 0.3s ease-out both; }
.day-card-header { background: var(--brand-light); padding: 20rpx 32rpx; display: flex; justify-content: space-between; align-items: center; border-bottom: 2rpx solid rgba(184, 208, 96, 0.2); }
.day-title { font-size: 30rpx; font-weight: 700; color: var(--text-main); }
.day-date { font-size: 24rpx; color: var(--brand-dark); font-weight: 600; }

.meal-row { padding: 32rpx; display: flex; gap: 24rpx; border-bottom: 1rpx solid rgba(0, 0, 0, 0.02); align-items: flex-start; }
.meal-row:last-child { border-bottom: none; }
.meal-badge { width: 72rpx; height: 72rpx; background: #fdfdfd; color: var(--brand-dark); border: 2rpx solid var(--brand-light); border-radius: 36rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 800; flex-shrink: 0; box-shadow: 0 4rpx 12rpx rgba(184, 208, 96, 0.1); }
.meal-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.meal-main { font-size: 30rpx; font-weight: 700; color: var(--text-main); margin-bottom: 12rpx; line-height: 1.6; display: flex; flex-direction: column; gap: 8rpx; }
.meal-main-item { position: relative; padding-left: 24rpx; }
.meal-main-item::before { content: ''; position: absolute; left: 0; top: 18rpx; width: 8rpx; height: 8rpx; border-radius: 50%; background: var(--brand-primary); }
.meal-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 8rpx; }
.meal-note { font-size: 22rpx; color: var(--text-muted); background: #f8f8f8; padding: 4rpx 16rpx; border-radius: 8rpx; }
.meal-kcal { font-size: 24rpx; color: var(--brand-dark); font-weight: 700; display: flex; align-items: center; gap: 4rpx; }
.rest-card { background: var(--bg-card); border: 2rpx dashed rgba(184, 208, 96, 0.3); border-radius: 32rpx; padding: 48rpx; text-align: center; color: var(--text-sub); font-size: 28rpx; font-weight: 500; margin-bottom: 32rpx; box-shadow: var(--shadow-sm); }
