.service-hero {
  margin: -40rpx 24rpx 20rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, #f7f9ee 100%);
  box-shadow: 0 10rpx 28rpx rgba(146, 170, 64, 0.12);
  position: relative;
  z-index: 3;
}

.service-hero__eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--brand-dark);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.service-hero__title {
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: var(--text-main);
  line-height: 1.35;
}

.service-hero__desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

.service-pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.service-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid rgba(146, 170, 64, 0.2);
  color: var(--brand-dark);
  font-size: 22rpx;
  font-weight: 700;
}

.service-hero__cta {
  margin-top: 24rpx;
  width: 100%;
  border: none;
  border-radius: 999rpx;
  background: var(--brand-primary);
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.service-hero__cta::after {
  border: none;
}

.service-guide-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: var(--shadow-sm);
}

.service-guide-card__title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main);
}

.service-guide-card__item {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  align-items: flex-start;
}

.service-guide-card__index {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--brand-light);
  color: var(--brand-dark);
  font-size: 22rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.service-guide-card__text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

/* =========================================
   全屏强制公告
   ========================================= */
.fullscreen-announcement {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: linear-gradient(160deg, #f7f9ee 0%, #e8f0d0 40%, #dce6c0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 64rpx 40rpx 120rpx;
  box-sizing: border-box;
}

.fullscreen-announcement__content {
  width: 100%;
  max-width: 620rpx;
  text-align: center;
}

.fullscreen-announcement__badge {
  display: inline-block;
  padding: 8rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(146, 170, 64, 0.18);
  color: #92aa40;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.fullscreen-announcement__title {
  margin-top: 32rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: #2d3a1a;
  line-height: 1.3;
}

.fullscreen-announcement__body {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.fullscreen-announcement__line {
  font-size: 28rpx;
  line-height: 1.75;
  color: #4a5a2e;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 16rpx;
}

.fullscreen-announcement__hint {
  margin-top: 56rpx;
  font-size: 22rpx;
  color: #92aa40;
  opacity: 0.7;
  letter-spacing: 1rpx;
}

.meal-reminder-popup {
  position: fixed;
  inset: 0;
  z-index: 9999;
}

.meal-reminder-popup__mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.46);
  backdrop-filter: blur(8rpx);
}

.meal-reminder-popup__panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 40rpx 32rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #fffdf6 0%, #ffffff 52%, #f8fbef 100%);
  box-shadow: 0 30rpx 80rpx rgba(31, 41, 55, 0.18);
}

.meal-reminder-popup__badge {
  display: inline-flex;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(146, 170, 64, 0.14);
  color: #7f9533;
  font-size: 22rpx;
  font-weight: 700;
}

.meal-reminder-popup__title {
  margin-top: 24rpx;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.35;
  color: #1f2937;
}

.meal-reminder-popup__message {
  margin-top: 20rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #4b5563;
}

.meal-reminder-popup__check {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #556274;
  font-size: 24rpx;
}

.meal-reminder-popup__checkbox {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  border: 2rpx solid rgba(146, 170, 64, 0.4);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: transparent;
  background: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.meal-reminder-popup__checkbox.is-checked {
  background: #92aa40;
  border-color: #92aa40;
  color: #ffffff;
}

.meal-reminder-popup__button {
  margin-top: 32rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #cfe37a 0%, #b8d060 100%);
  color: #243018;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 88rpx;
}

.meal-reminder-popup__button::after {
  border: none;
}

.hero-banner-copy {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 34rpx;
  padding: 24rpx 24rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.08) 0%, rgba(15, 23, 42, 0.72) 100%);
  color: #ffffff;
  z-index: 2;
}

.hero-banner-copy__title {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
}

.hero-banner-copy__action {
  display: inline-flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-banner-copy__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  opacity: 0.92;
}

.hero-banner-copy__hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  opacity: 0.86;
}

/* =========================================
   轮播图指示器美化
   ========================================= */
.hero-swiper .wx-swiper-dots {
  bottom: 16rpx !important;
}

.hero-swiper .wx-swiper-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  margin: 0 6rpx;
  background: rgba(255, 255, 255, 0.4);
  transition: all 0.25s ease;
}

.hero-swiper .wx-swiper-dot-active {
  width: 24rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.95);
}
