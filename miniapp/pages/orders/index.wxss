.order-card {
  padding: 30rpx 28rpx;
  transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
}

.order-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.order-title-wrap {
  flex: 1;
  min-width: 0;
}

.order-kicker-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
}

.order-date-label {
  margin-bottom: 0;
}

.order-source-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f5f7ea;
  color: #7a8f33;
  font-size: 22rpx;
  font-weight: 700;
}

.order-title {
  margin-top: 16rpx;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  color: #1e293b;
}

.order-head-side {
  display: flex;
  align-items: flex-start;
}

.status-pill {
  padding: 6rpx 20rpx;
  border-radius: 99rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-pill.pending { background: #fef9c3; color: #854d0e; }
.status-pill.processing { background: #dcfce7; color: #166534; }
.status-pill.cancelled { background: #f1f5f9; color: #475569; }
.status-pill.refunded { background: #fee2e2; color: #991b1b; }

.order-address-panel {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #fafaf8;
}

.order-address-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.order-address-value {
  font-size: 28rpx;
  line-height: 1.6;
  font-weight: 700;
  color: #1e293b;
  word-break: break-all;
}

.order-meta-line {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.order-note-stack {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-note-item {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.order-note-key {
  width: 120rpx;
  flex-shrink: 0;
  color: #94a3b8;
}

.order-note-value {
  flex: 1;
  color: #475569;
  word-break: break-all;
}

.action-row-wrap {
  display: flex;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.order-primary-btn {
  min-width: 220rpx;
}

.order-secondary-btn {
  min-width: 172rpx;
}
