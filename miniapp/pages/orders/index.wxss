.order-card {
  padding: 0;
  border-radius: 24rpx;
  background: #ffffff;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
  margin-bottom: 24rpx;
}

.order-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.order-time-wrap {
  display: flex;
  align-items: center;
}

.order-time {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.order-status {
  font-size: 24rpx;
  font-weight: 600;
}

.order-status.pending { color: #d97706; }
.order-status.processing { color: #16a34a; }
.order-status.cancelled { color: #94a3b8; }
.order-status.refunded { color: #dc2626; }

.detail-icon {
  margin-left: 4rpx;
  font-weight: 400;
}

.order-card-body {
  padding: 24rpx 28rpx;
}

.order-main-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.order-meal-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #1e293b;
  width: 100%;
}

.order-guidance {
  font-size: 22rpx;
  color: #f59e0b;
  background: #fef3c7;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.order-detail-list {
  background: #fafaf8;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  font-size: 24rpx;
  line-height: 1.5;
}

.detail-label {
  color: #94a3b8;
  width: 100rpx;
  flex-shrink: 0;
}

.detail-value {
  color: #475569;
  flex: 1;
  word-break: break-all;
}

.highlight-note {
  color: #d97706;
  font-weight: 500;
}

.order-card-footer {
  padding: 20rpx 28rpx;
  border-top: 1rpx solid #f1f5f9;
  display: flex;
  justify-content: center;
}

.action-btn-group {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.action-btn {
  margin: 0;
  padding: 0 28rpx;
  height: 60rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}

.action-btn::after {
  border: none;
}

.action-btn.outline {
  background: #ffffff;
  color: #64748b;
  border: 1rpx solid #cbd5e1;
}

.action-btn.primary {
  background: #92AA40;
  color: #ffffff;
  border: 1rpx solid #92AA40;
}

.target-order-hint {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  font-size: 24rpx;
  color: #64748b;
}

.target-order-btn {
  min-width: 188rpx;
}
