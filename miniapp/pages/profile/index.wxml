<!-- =====================================
      Tab 3：我的页
      ===================================== -->
<view id="tab-profile" class="content">
  <view class="profile-header">
    <view class="profile-meta">
      <view class="profile-name" bindtap="goEditProfile">
        {{displayName}}
        <text wx:if="{{!onboarding}}" class="edit-icon">✎</text>
      </view>
      <view class="profile-sub" wx:if="{{!onboarding}}">{{maskedPhone}}</view>
      <view class="profile-badge member" wx:if="{{!onboarding}}">会员已开通</view>
      <view class="profile-guest-action" wx:if="{{onboarding}}" bindtap="openAuthPopup">
        去登录 <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="vip-card" wx:if="{{!onboarding}}">
    <view class="vip-title">当前剩余餐数</view>
    <view class="vip-balance"><text class="num">{{home ? home.remainingMeals : '--'}}</text><text class="unit">餐</text></view>
    <view class="member-copy">{{home ? home.orderStatusText : '会员预订专享'}}</view>
    <view class="vip-footer">
      <view class="vip-status">会员预订专享</view>
      <view class="btn-outline" bindtap="goWallet">餐次流水单</view>
    </view>
  </view>

  <view class="menu-group">
    <view class="list-item {{onboarding ? 'disabled' : ''}}" bindtap="goOrders">
      <view class="list-copy">
        <view class="list-title">我的预订记录</view>
      </view>
      <text class="list-arrow">›</text>
    </view>
    <view class="list-item {{onboarding ? 'disabled' : ''}}" bindtap="goReceipts">
      <view class="list-copy">
        <view class="list-title">每日送达回执</view>
      </view>
      <text class="list-arrow">›</text>
    </view>
  </view>
  <view class="menu-group">
    <view class="list-item {{onboarding ? 'disabled' : ''}}" bindtap="goAddresses">
      <view class="list-copy">
        <view class="list-title">收餐地址管理</view>
      </view>
      <text class="list-arrow">›</text>
    </view>
    <button class="list-item list-item-btn {{onboarding ? 'disabled' : ''}}" bindtap="contactService" open-type="{{onboarding ? '' : 'contact'}}">
      <view class="list-copy">
        <view class="list-title">联系专属客服</view>
      </view>
      <text class="list-arrow">›</text>
    </button>
  </view>

  <view class="logout-section" wx:if="{{!onboarding}}">
    <button class="btn-logout" bindtap="handleLogout">退出登录</button>
  </view>

  <!-- 半屏登录弹窗 -->
  <view class="auth-popup-mask {{showAuthPopup ? 'show' : ''}}" bindtap="closeAuthPopup"></view>
  <view class="auth-popup-container {{showAuthPopup ? 'show' : ''}}">
    <view class="auth-popup-header">
      <view class="auth-popup-title">
        {{authFlowMode === 'login' ? '登录会员账号' : '填写姓名完成注册'}}
      </view>
      <view class="auth-popup-close" bindtap="closeAuthPopup">×</view>
    </view>
    <view class="auth-popup-body">
      <view class="auth-form-group" wx:if="{{authFlowMode !== 'complete-profile'}}">
        <view class="auth-form-item auth-form-item-last">
          <view class="auth-form-label">手机号</view>
          <input class="auth-form-input" type="number" maxlength="11" placeholder="输入11位手机号" value="{{profileForm.phoneNumber}}" bindinput="onPhoneInput" />
        </view>
      </view>

      <view class="phone-hint" wx:if="{{phoneAuthHint}}">
        已填写：<text class="phone-hint-val">{{phoneAuthHint}}</text>
      </view>

      <view class="auth-form-group" wx:if="{{authFlowMode !== 'login'}}">
        <view class="auth-form-item auth-form-item-last">
          <view class="auth-form-label">姓名</view>
          <input class="auth-form-input" type="nickname" maxlength="20" placeholder="请输入姓名" value="{{profileForm.nickname}}" bindinput="onNicknameInput" />
        </view>
      </view>

      <block wx:if="{{authFlowMode === 'login'}}">
        <button
          class="auth-submit-btn auth-entry-btn"
          loading="{{savingProfile}}"
          disabled="{{savingProfile}}"
          bindtap="submitProfile"
        >手机号登录</button>

        <button
          class="btn-wechat-alt auth-entry-btn"
          bindtap="preparePhonePrivacyPermission"
          open-type="getPhoneNumber"
          bindgetphonenumber="getPhoneNumber"
          loading="{{savingProfile}}"
        >微信一键登录</button>

        <view class="phone-auth-hint">首次使用会先拉起微信隐私授权，再弹出默认手机号确认框</view>

        <view class="auth-register-link" bindtap="startRegisterFlow">新用户注册</view>
      </block>

      <block wx:else>
        <button
          class="auth-submit-btn"
          loading="{{savingProfile}}"
          disabled="{{savingProfile}}"
          bindtap="submitProfile"
        >完成注册</button>

        <view class="auth-register-link" wx:if="{{authFlowMode === 'register'}}" bindtap="openAuthPopup">已有账号，返回登录</view>
      </block>
    </view>
  </view>
</view>
