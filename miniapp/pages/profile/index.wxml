<!-- =====================================
      Tab 3：我的页
      ===================================== -->
<view id="tab-profile" class="content">
  <view class="profile-header">
    <view class="profile-meta">
      <view class="profile-name" bindtap="goEditProfile">
        {{displayName}}
        <text wx:if="{{!onboarding}}" class="edit-icon">✎</text>
      </view>
      <view class="profile-sub" wx:if="{{!onboarding}}">{{maskedPhone}}</view>
      <view class="profile-badge member" wx:if="{{!onboarding}}">会员已开通</view>
      <view class="profile-guest-action" wx:if="{{onboarding}}" bindtap="goLoginPage">
        去登录 <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="vip-card" wx:if="{{!onboarding}}">
    <view class="vip-title">当前剩余餐数</view>
    <view class="vip-balance"><text class="num">{{home ? home.remainingMeals : '--'}}</text><text class="unit">餐</text></view>
    <view class="member-copy">{{home ? home.orderStatusText : '会员预订专享'}}</view>
    <view class="vip-footer">
      <view class="vip-status">会员预订专享</view>
      <view class="btn-outline" bindtap="goWallet">餐次流水单</view>
    </view>
  </view>

  <view class="menu-group">
    <view class="list-item {{onboarding ? 'disabled' : ''}}" bindtap="goOrders">
      <view class="list-icon-wrap">
        <text class="list-icon">📝</text>
        <view class="list-copy">
          <view class="list-title">我的预订记录</view>
        </view>
      </view>
      <text class="list-arrow">›</text>
    </view>
    <view class="list-item {{onboarding ? 'disabled' : ''}}" bindtap="goReceipts">
      <view class="list-icon-wrap">
        <text class="list-icon">📸</text>
        <view class="list-copy">
          <view class="list-title">每日送达回执</view>
        </view>
      </view>
      <text class="list-arrow">›</text>
    </view>
  </view>
  <view class="menu-group">
    <view class="list-item {{onboarding ? 'disabled' : ''}}" bindtap="goAddresses">
      <view class="list-icon-wrap">
        <text class="list-icon">📍</text>
        <view class="list-copy">
          <view class="list-title">收餐地址管理</view>
        </view>
      </view>
      <text class="list-arrow">›</text>
    </view>
    <button class="list-item list-item-btn {{onboarding ? 'disabled' : ''}}" bindtap="contactService" open-type="{{onboarding ? '' : 'contact'}}">
      <view class="list-icon-wrap">
        <text class="list-icon">💬</text>
        <view class="list-copy">
          <view class="list-title">联系专属客服</view>
        </view>
      </view>
      <text class="list-arrow">›</text>
    </button>
  </view>

  <view class="logout-section" wx:if="{{!onboarding}}">
    <button class="btn-logout" bindtap="handleLogout">退出登录</button>
  </view>

</view>
