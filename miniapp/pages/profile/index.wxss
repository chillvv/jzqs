.profile-name {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
  word-break: break-all;
}

.profile-meta {
  flex: 1;
  min-width: 0;
}

.profile-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-sub);
  word-break: break-all;
}

.profile-badge {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.profile-guest-action {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: var(--brand-light);
  color: var(--brand-dark);
  font-size: 24rpx;
  font-weight: 700;
  gap: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(184, 208, 96, 0.2);
  border: 2rpx solid rgba(184, 208, 96, 0.4);
}

.profile-guest-action .arrow {
  font-family: Arial, sans-serif;
  font-weight: normal;
  color: #999999;
}

.profile-badge.member {
  background: #eef9f0;
  color: #237b4b;
}

.guest-service-card {
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7f9ee 100%);
  box-shadow: var(--shadow-sm);
}

.guest-service-card__title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
}

.guest-service-card__desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

.guest-service-card__primary,
.guest-service-card__secondary {
  margin-top: 24rpx;
  width: 100%;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.guest-service-card__primary {
  background: var(--brand-primary);
  color: #111111;
}

.guest-service-card__secondary {
  background: #ffffff;
  color: var(--text-main);
  border: 2rpx solid var(--border);
}

.guest-service-card__primary::after,
.guest-service-card__secondary::after {
  border: none;
}

.list-icon-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.list-icon {
  font-size: 32rpx;
  line-height: 1;
}

.list-copy {
  flex: 1;
  min-width: 0;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  word-break: break-all;
}

.list-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-sub);
  word-break: break-all;
}

.list-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 32rpx;
  line-height: 1;
  color: #bbbbbb;
  font-family: Arial, sans-serif;
}

.member-copy,
.auth-form-hint,
.phone-auth-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-sub);
  word-break: break-all;
}

.edit-icon {
  display: inline-block;
  margin-left: 8rpx;
  font-size: 24rpx;
  line-height: 1;
  color: var(--text-sub);
}


/* 完善信息弹窗 UI */
.auth-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.auth-popup-mask.show {
  visibility: visible;
  opacity: 1;
}

.auth-popup-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F5F6F7;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  max-height: 86vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.auth-popup-container.show {
  transform: translateY(0);
}

.auth-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx 20rpx;
}

.auth-popup-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1A1A1A;
}

.auth-popup-close {
  font-size: 44rpx;
  color: #999;
  line-height: 1;
  padding: 10rpx;
  font-weight: 300;
}

.auth-popup-body {
  flex: 1;
  min-height: 0;
  padding: 0 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.auth-popup-footer {
  flex-shrink: 0;
  padding: 0 40rpx calc(env(safe-area-inset-bottom) + 32rpx);
  background: linear-gradient(180deg, rgba(247, 248, 250, 0) 0%, #f7f8fa 20%);
  overflow: visible;
}

.auth-popup-agreement-stack {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.auth-popup-copy {
  margin-bottom: 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #666666;
}

.auth-agreement {
  margin-bottom: 28rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1px solid #eeeeee;
}

.auth-agreement-label {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  color: #4b5563;
  line-height: 1.7;
}

.auth-agreement-text {
  font-size: 24rpx;
}

.auth-agreement-link {
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 700;
}

.auth-form-group {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  border: 1px solid #EEEEEE;
}

.auth-form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #EEEEEE;
  min-height: 104rpx;
}

.auth-form-item.border-none {
  border-bottom: none;
  display: block;
  padding: 0;
  min-height: 0;
}

.auth-form-label {
  width: 120rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 600;
  flex-shrink: 0;
}

.auth-avatar-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  background: transparent;
  padding: 0;
  margin: 0;
  text-align: right;
  line-height: normal;
  min-height: 92rpx;
}

.auth-avatar-btn::after {
  border: none;
}

.auth-avatar-img {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #F5F6F7;
  border: 2rpx solid #EEEEEE;
}

.auth-avatar-arrow {
  font-size: 44rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
  font-family: Arial, sans-serif;
}

.auth-form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  text-align: left;
  padding-left: 24rpx;
  min-height: 52rpx;
  line-height: 52rpx;
}

.auth-form-input::placeholder {
  color: #999999;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1px solid #eeeeee;
  min-height: 120rpx;
}

.label {
  width: 128rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  flex-shrink: 0;
}

.phone-input {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: #333333;
  padding-right: 24rpx;
  min-height: 52rpx;
  line-height: 52rpx;
}

.ph-color {
  color: #999999;
}

.quick-get-btn {
  background: transparent;
  margin: 0;
  outline: none;
  border: 2rpx solid #b3cf64;
  color: #b3cf64;
  font-size: 24rpx;
  font-weight: 600;
  height: 58rpx;
  line-height: 54rpx;
  border-radius: 29rpx;
  padding: 0 24rpx;
  flex-shrink: 0;
}

.quick-get-btn::after {
  border: none;
}

.phone-auth-panel {
  padding: 32rpx 0 36rpx;
}

.phone-auth-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.phone-auth-value {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #999999;
}

.phone-auth-value.authorized {
  color: var(--brand-dark);
  font-weight: 700;
}

.phone-manual-input {
  margin-top: 20rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  background: #F5F6F7;
  border-radius: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #EEEEEE;
}

.phone-manual-input::placeholder {
  color: #BBBBBB;
  font-size: 28rpx;
}

.phone-manual-input:focus {
  border-color: var(--brand-primary);
}

.phone-auth-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999999;
}

/* (Removed unused auth-agreement) */

.auth-submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: var(--brand-primary);
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(184, 208, 96, 0.25);
  margin: 0 auto;
  display: block;
  text-align: center;
  padding: 0;
}

.auth-submit-btn::after {
  border: none;
}

/* 禁用状态 */
.auth-submit-btn[disabled] {
  opacity: 0.6;
}

.auth-entry-btn {
  width: 320rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
}

.auth-register-link {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--brand-dark);
}

.auth-dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1002;
}

.auth-dialog {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 1003;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.18);
}

.auth-dialog-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.auth-dialog-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #666666;
}

.auth-dialog-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.auth-dialog-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 0;
}

.auth-dialog-btn::after {
  border: none;
}

.auth-dialog-btn-secondary {
  background: #f3f4f6;
  color: #374151;
}

.auth-dialog-btn-primary {
  background: var(--brand-primary);
  color: #111111;
}

/* 微信快捷登录 (次要按钮) */
.btn-wechat-alt {
  background: #07C160;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  margin: 0 auto;
  margin: 20rpx auto 0;
}

.btn-wechat-alt::after { border: none; }
.btn-wechat-alt:active { opacity: 0.8; }

/* 分隔线 */
.or-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 64rpx 0 40rpx;
  color: #AAAAAA;
  font-size: 24rpx;
  gap: 24rpx;
}

.or-divider::before,
.or-divider::after {
  content: '';
  width: 60rpx;
  height: 1px;
  background: #EEEEEE;
}

/* 表单项 */
.auth-form-item-last {
  border-bottom: none !important;
}

/* 手机号已填写提示 */
.phone-hint {
  font-size: 24rpx;
  color: #999;
  margin: -12rpx 0 32rpx;
  padding: 0 4rpx;
}

.phone-hint-val {
  color: #237b4b;
  font-weight: 600;
}

/* 协议二次确认弹窗（底部弹出样式） */
.auth-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 10000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.auth-dialog-mask.show {
  visibility: visible;
  opacity: 1;
}

.auth-dialog {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 10001;
  padding: 48rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.auth-dialog.show {
  transform: translateY(0);
}

.auth-dialog-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111111;
  text-align: center;
  margin-bottom: 24rpx;
}

.auth-dialog-copy {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666666;
  text-align: center;
  margin-bottom: 48rpx;
}

.auth-dialog-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.auth-dialog-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  margin: 0;
  padding: 0;
}

.auth-dialog-btn::after {
  border: none;
}

.auth-dialog-btn-secondary {
  background: #f5f5f5;
  color: #666666;
}

.auth-dialog-btn-primary {
  background: var(--brand-primary);
  color: #ffffff;
}

/* Auth popup refresh */
.auth-popup-container {
  background: #f7f8fa;
  box-shadow: 0 -16rpx 48rpx rgba(15, 23, 42, 0.12);
}

.auth-popup-body {
  gap: 20rpx;
}

.auth-form-group {
  margin-bottom: 8rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.auth-entry-btn {
  width: 320rpx !important;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
}

.btn-wechat-alt {
  margin: 0 auto;
  box-shadow: 0 10rpx 24rpx rgba(7, 193, 96, 0.18);
}

.auth-register-link {
  margin-top: 8rpx;
}

.auth-submit-btn {
  margin: 0 auto;
  box-shadow: 0 10rpx 24rpx rgba(37, 99, 235, 0.16);
}

.auth-agreement-bar {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 8rpx 0;
  border-top: 1px solid rgba(203, 213, 225, 0.65);
}

.auth-agreement-copy-line {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.7;
  color: #6b7280;
}

.auth-agreement-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-top: 2rpx;
  border-radius: 50%;
  border: 2rpx solid #cbd5e1;
  background: #ffffff;
  box-sizing: border-box;
  flex-shrink: 0;
}

.auth-agreement-icon.checked {
  border-color: var(--brand-primary);
  background: var(--brand-primary);
}

.auth-agreement-icon-mark {
  font-size: 20rpx;
  color: #ffffff;
  line-height: 1;
}

.auth-agreement-sheet {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  margin: 0 8rpx;
  padding: 0 32rpx;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  box-shadow: 0 -10rpx 28rpx rgba(15, 23, 42, 0.12);
  transform: translateY(12rpx);
  transition: max-height 0.28s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.22s ease, transform 0.28s cubic-bezier(0.2, 0.8, 0.2, 1), padding 0.28s ease, margin-bottom 0.28s ease;
}

.auth-agreement-sheet.show {
  max-height: 720rpx;
  opacity: 1;
  margin-bottom: 12rpx;
  padding: 20rpx 32rpx 28rpx;
  transform: translateY(0);
}

.auth-agreement-sheet-handle {
  width: 88rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #d1d5db;
}

.auth-agreement-sheet-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
  text-align: center;
}

.auth-agreement-sheet-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
  text-align: center;
}

.auth-agreement-sheet-link-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.auth-agreement-sheet-link-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.auth-agreement-sheet-link-arrow {
  font-size: 32rpx;
  color: #94a3b8;
  font-family: Arial, sans-serif;
}

.auth-agreement-sheet-check {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 28rpx;
  padding: 8rpx 4rpx;
}

.auth-agreement-sheet-check-text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.7;
  color: #374151;
}

.auth-agreement-sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.auth-agreement-sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.auth-agreement-sheet-btn::after {
  border: none;
}

.auth-agreement-sheet-btn-secondary {
  background: #eef2f7;
  color: #4b5563;
}

.auth-agreement-sheet-btn-primary {
  background: var(--brand-primary);
  color: #ffffff;
}
