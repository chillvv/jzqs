/* =========================================
   详情页基础样式（从 app.wxss 拆入）
   ========================================= */

.detail-page-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-hero-card {
  padding: 32rpx 28rpx 28rpx;
  background: linear-gradient(180deg, #f7f9ee 0%, var(--bg-card) 72%);
  border: none;
  box-shadow: 0 10rpx 28rpx rgba(146, 170, 64, 0.12);
}

.detail-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 22rpx;
  gap: 24rpx;
}

.detail-status-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(146, 170, 64, 0.14);
  color: var(--brand-dark);
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.detail-status-title {
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 800;
  color: var(--text-main);
  flex: 1;
  word-break: break-all;
}

.detail-status-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-sub);
}

.detail-hero-meta {
  margin-top: 28rpx;
  display: flex;
  gap: 20rpx;
}

.detail-hero-meta-item {
  flex: 1;
  min-width: 0;
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(146, 170, 64, 0.12);
}

.detail-hero-meta-label {
  font-size: 22rpx;
  color: var(--text-sub);
  margin-bottom: 10rpx;
}

.detail-hero-meta-value {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.5;
  word-break: break-all;
}

.detail-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.detail-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  border: 2rpx solid rgba(184, 208, 96, 0.22);
  color: var(--text-sub);
  font-size: 22rpx;
  font-weight: 700;
}

.detail-section-card {
  padding: 28rpx;
  border: none;
}

.detail-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main);
}

.detail-section-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
  text-align: right;
}

.detail-info-list {
  background: var(--bg-card-alt);
  border-radius: 24rpx;
  padding: 0 24rpx;
}

.detail-info-row {
  display: flex;
  gap: 20rpx;
  padding: 22rpx 0;
  border-top: 2rpx solid rgba(26, 26, 26, 0.06);
}

.detail-info-row:first-of-type {
  border-top: none;
  padding-top: 0;
}

.detail-info-row:last-of-type {
  padding-bottom: 0;
}

.detail-info-primary {
  padding-top: 24rpx;
}

.detail-info-label {
  width: 132rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--text-sub);
  line-height: 1.7;
}

.detail-info-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-main);
  line-height: 1.7;
  word-break: break-all;
}

.detail-address-text {
  font-weight: 700;
}

.detail-strong-value {
  font-weight: 700;
}

.rider-note-block {
  margin-top: 0;
}

.rider-note-text {
  font-weight: 700;
}

.receipt-photo-panel {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--bg-card-alt);
}

.receipt-photo-panel-title {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 18rpx;
}

.receipt-photo {
  width: 100%;
  border-radius: 22rpx;
  background: var(--brand-light);
  overflow: hidden;
  display: block;
}

.receipt-photo-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-sub);
}

.receipt-inline-hint {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: var(--bg-card-alt);
  font-size: 24rpx;
  color: var(--text-sub);
  line-height: 1.6;
}

/* =========================================
   回执页覆盖样式
   ========================================= */

.detail-hero-card {
  background: linear-gradient(180deg, #f8fbef 0%, var(--bg-card) 100%);
}

.detail-hero-top {
  display: flex;
  justify-content: flex-end;
}

.detail-status-title {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.detail-status-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.detail-section-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1e293b;
}

.detail-info-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.detail-info-row {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.detail-info-label {
  color: #94a3b8;
}

.detail-info-value {
  font-size: 26rpx;
  line-height: 1.6;
  color: #334155;
  word-break: break-all;
}

.detail-address-text,
.rider-note-text {
  color: #0f172a;
  font-weight: 600;
}

.receipt-photo-panel {
  border-radius: 24rpx;
  background: #f8fafc;
  padding: 20rpx;
}

.receipt-photo {
  width: 100%;
  border-radius: 20rpx;
  overflow: hidden;
}

.receipt-photo-hint,
.receipt-inline-hint,
.detail-line {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}
