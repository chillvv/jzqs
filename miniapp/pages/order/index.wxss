/* pages/order/index.wxss */

.rule-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, var(--bg-card) 0%, #f7f9ee 100%);
  box-shadow: var(--shadow-sm);
}

.rule-card__title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main);
}

.rule-card__item {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

.inline-auth-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.48);
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
  z-index: 1001;
}

.inline-auth-mask.show {
  opacity: 1;
  visibility: visible;
}

.inline-auth-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  padding: 40rpx 32rpx;
  border-radius: 40rpx 40rpx 0 0;
  background: var(--bg-card);
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.1);
  transform: translateY(120%);
  transition: transform 0.24s cubic-bezier(0.175, 0.885, 0.32, 1.1);
  z-index: 1002;
}

.inline-auth-sheet.show {
  transform: translateY(0);
}

.inline-auth-sheet__header {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.inline-auth-sheet__title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-main);
}

.inline-auth-sheet__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-sub);
}

.inline-auth-sheet__close {
  font-size: 40rpx;
  line-height: 1;
  color: var(--text-muted);
  padding: 4rpx 0 0 12rpx;
}

.inline-auth-sheet__primary,
.inline-auth-sheet__secondary {
  margin-top: 24rpx;
  width: 100%;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.inline-auth-sheet__primary {
  background: var(--brand-primary);
  color: #111111;
}

.inline-auth-sheet__secondary {
  background: var(--bg-card);
  color: var(--text-main);
  border: 2rpx solid var(--border);
}

.inline-auth-sheet__primary::after,
.inline-auth-sheet__secondary::after {
  border: none;
}

.remark-default-card {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.remark-default-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.remark-default-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
}

.remark-default-value {
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-sub);
}

.remark-default-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* =========================================
   Tab 2：点餐页 + 购物车 + 结算（从 app.wxss 拆入）
   ========================================= */
#view-menu { display: block; padding-bottom: calc(200rpx + env(safe-area-inset-bottom)); min-height: 100vh;}
#view-checkout { background: var(--bg-app); min-height: 100vh; padding-bottom: calc(420rpx + env(safe-area-inset-bottom)); }

.menu-top { background: var(--bg-card); padding: 32rpx; margin-bottom: 24rpx; }
.menu-top-title { font-size: 40rpx; font-weight: 800; margin-bottom: 8rpx; color: var(--text-main); }
.menu-top-desc { font-size: 26rpx; color: var(--text-sub); }

.menu-list-wrap { padding: 0 24rpx; display: flex; flex-direction: column; gap: 48rpx; }

.meal-item { background: var(--bg-card); border-radius: 32rpx; padding: 32rpx; display: flex; gap: 24rpx; box-shadow: var(--shadow-sm); position: relative; border: 2rpx solid #fcfcfc; }
.meal-img { width: 180rpx; height: 180rpx; border-radius: 32rpx; flex-shrink: 0; display: block; border: 1rpx solid rgba(0, 0, 0, 0.04); background-color: #f8f8f8; box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,0.04); }
.meal-content { flex: 1; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.meal-title { font-size: 40rpx; font-weight: 900; color: var(--text-main); margin-bottom: 8rpx; letter-spacing: 1rpx; }
.meal-desc { font-size: 24rpx; color: var(--text-sub); line-height: 1.8; margin-bottom: 20rpx; }
.meal-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.meal-tag { font-size: 20rpx; background: #f7f8f2; color: var(--brand-dark); padding: 4rpx 14rpx; border-radius: 8rpx; font-weight: 700; }
.meal-bottom { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 16rpx; }
.meal-price-box { font-size: 24rpx; color: var(--text-muted); opacity: 0; transition: opacity 0.2s; }
.meal-price-box.show { opacity: 1; }
.meal-price-box text { font-size: 20rpx; margin-left: 2rpx; }
.stepper { display: flex; align-items: center; background: var(--bg-card); border: 1rpx solid #f0f0f0; border-radius: 32rpx; padding: 4rpx; transition: border-color 0.3s; }
.stepper.active { background: var(--bg-card); border-color: var(--brand-dark); }
.step-btn { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; font-size: 38rpx; font-weight: 200; color: var(--text-main); transition: transform 0.15s cubic-bezier(0.4, 0, 0.2, 1); }
.step-btn:active { transform: scale(0.9); }
.step-btn.minus { color: var(--text-muted); }
.step-btn.plus { color: var(--brand-dark); font-weight: 400; }
.step-num { min-width: 60rpx; text-align: center; font-size: 30rpx; font-weight: 600; color: var(--text-main); }

/* 购物车底栏 */
.cart-bar { position: fixed; bottom: calc(136rpx + env(safe-area-inset-bottom) + 24rpx); left: 32rpx; right: 32rpx; height: 112rpx; background: linear-gradient(135deg, rgba(40, 40, 40, 0.7) 0%, rgba(10, 10, 10, 0.85) 100%); backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px); border: 2rpx solid rgba(255, 255, 255, 0.15); border-radius: 56rpx; display: flex; align-items: center; justify-content: space-between; padding: 0 12rpx 0 40rpx; z-index: 100; transform: translateY(200rpx); visibility: hidden; opacity: 0; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.25); }
.cart-bar.show { transform: translateY(0); visibility: visible; opacity: 1; }
.cart-info { display: flex; align-items: baseline; gap: 12rpx; }
.cart-total { font-size: 44rpx; font-weight: 900; color: var(--brand-primary); }
.cart-total text { font-size: 24rpx; margin-left: 4rpx; color: var(--brand-primary); }
.cart-desc { font-size: 24rpx; color: rgba(255, 255, 255, 0.95); font-weight: 900; }
.btn-checkout { background: var(--brand-primary); color: #111; border: none; height: 88rpx; line-height: 88rpx; padding: 0 48rpx; border-radius: 44rpx; font-size: 30rpx; font-weight: 900; margin: 0; }
.btn-checkout[disabled] { opacity: 0.5; background: var(--text-sub); color: var(--text-muted); }

/* 结算视图 */
.checkout-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.6);
  padding: 0 24rpx;
  z-index: 120;
  box-sizing: border-box;
}

.checkout-scroll { padding: 24rpx; }

.address-card { background: linear-gradient(180deg, var(--bg-card) 0%, #fdfdfd 100%); border-radius: 32rpx; padding: 40rpx; display: flex; align-items: center; justify-content: space-between; gap: 24rpx; box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.06); margin: 24rpx; border: 2rpx solid rgba(184, 208, 96, 0.15); position: relative; overflow: hidden; }
.address-card::before { content: ''; position: absolute; left: 0; bottom: 0; right: 0; height: 6rpx; background: repeating-linear-gradient(45deg, var(--brand-primary) 0, var(--brand-primary) 20rpx, transparent 20rpx, transparent 32rpx, #ffb347 32rpx, #ffb347 52rpx, transparent 52rpx, transparent 64rpx); opacity: 0.6; }
.addr-empty { font-size: 34rpx; font-weight: 800; color: var(--brand-dark); }
.addr-detail { font-size: 32rpx; font-weight: 800; color: var(--text-main); margin-bottom: 8rpx; display: flex; align-items: flex-start; gap: 16rpx; line-height: 1.5; }
.addr-tag { display: none; }
.addr-user { font-size: 26rpx; color: var(--text-sub); font-weight: 500; }
.addr-left-icon { font-size: 40rpx; margin-right: -8rpx; }
.addr-content { flex: 1; min-width: 0; }
.change-text { font-size: 26rpx; color: var(--brand-dark); font-weight: 700; }

.order-summary-card { background: var(--bg-card); border-radius: 32rpx; padding: 32rpx; box-shadow: var(--shadow-sm); margin-bottom: 24rpx; border: 2rpx solid #fdfdfd; }
.osc-title { font-size: 32rpx; font-weight: 800; border-bottom: 2rpx dashed var(--border); padding-bottom: 24rpx; margin-bottom: 24rpx; display: flex; justify-content: space-between; }
.osc-title .date { font-size: 26rpx; color: var(--text-sub); font-weight: normal; }

.checkout-item { display: flex; gap: 24rpx; margin-bottom: 32rpx; }
.checkout-item:last-child { margin-bottom: 0; }
.ci-img { width: 112rpx; height: 112rpx; border-radius: 20rpx; display: block; flex-shrink: 0; background-color: #e8e8e8; }
.ci-info { flex: 1; }
.ci-name { font-size: 30rpx; font-weight: 700; color: var(--text-main); margin-bottom: 8rpx; }
.ci-desc { font-size: 24rpx; color: var(--text-muted); margin-bottom: 16rpx; }
.ci-bottom { display: flex; justify-content: space-between; align-items: center; }
.ci-qty { font-size: 26rpx; color: var(--text-sub); }
.ci-price { font-size: 30rpx; font-weight: 800; color: var(--text-main); }

.checkout-row-card { background: var(--bg-card); border-radius: 32rpx; box-shadow: var(--shadow-sm); margin-bottom: 24rpx; border: 2rpx solid #fdfdfd; }
.checkout-row { padding: 32rpx; display: flex; justify-content: space-between; align-items: center; border-bottom: 2rpx dashed var(--border); }
.checkout-row:last-child { border-bottom: none; }
.checkout-row-label { font-size: 30rpx; font-weight: 800; color: var(--text-main); }
.checkout-row-value { font-size: 28rpx; color: var(--text-muted); display: flex; align-items: center; gap: 8rpx; }
.checkout-row-value.remark-container { display: block; }

.remark-input { width: 100%; text-align: left; font-size: 28rpx; color: var(--text-main); background: #f8fafc; height: 76rpx; line-height: 76rpx; border-radius: 20rpx; padding: 0 24rpx; box-sizing: border-box; }

.remark-dropdown { position: absolute; top: 100%; right: 0; background: var(--bg-card); border: 2rpx solid var(--border); border-radius: 16rpx; box-shadow: var(--shadow-md); z-index: 100; max-height: 260rpx; overflow-y: auto; width: 400rpx; margin-top: 8rpx; display: block; }
.remark-dropdown-item { padding: 20rpx 24rpx; font-size: 26rpx; color: var(--text-main); border-bottom: 2rpx solid var(--border); text-align: left; }
.remark-dropdown-item:last-child { border-bottom: none; }
.remark-dropdown-item:active { background: #f5f6f7; }

.remark-preset-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.remark-history-block {
  margin-bottom: 20rpx;
}

.remark-history-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-muted);
  text-align: right;
  margin-bottom: 12rpx;
}

.remark-history-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 16rpx;
}

.remark-chip {
  padding: 10rpx 28rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 2rpx solid transparent;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
  transition: all 0.2s ease;
}

.remark-chip.active {
  background: var(--brand-light);
  border-color: var(--brand-color);
  color: var(--brand-color);
}

.btn-set-default {
  background: #f8fafc;
  border: 2rpx solid transparent;
  color: #94a3b8;
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.btn-set-default.active {
  background: var(--brand-light);
  border-color: var(--brand-dark);
  color: var(--brand-dark);
}

.remark-chip-secondary {
  background: var(--bg-card);
  border-color: #e2e8f0;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(136rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 140;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}
.submit-total { display: flex; align-items: baseline; gap: 8rpx; }
.submit-total-label { font-size: 26rpx; color: var(--text-main); }
.submit-total-num { font-size: 48rpx; font-weight: 800; color: var(--brand-dark); }
.submit-total-unit { font-size: 24rpx; color: var(--text-main); font-weight: 600; }
.btn-submit { background: var(--brand-primary); color: #111; border: none; padding: 0 60rpx; height: 96rpx; line-height: 96rpx; border-radius: 48rpx; font-size: 32rpx; font-weight: 800; margin: 0; box-shadow: 0 12rpx 24rpx rgba(184, 208, 96, 0.3); }
.btn-submit[disabled] {
  opacity: 0.56;
}

/* 地址半屏弹窗 */
.address-popup-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; opacity: 0; visibility: hidden; transition: all 0.2s ease; }
.address-popup-mask.show { opacity: 1; visibility: visible; }
.address-popup-container { position: fixed; bottom: 0; left: 0; right: 0; background: var(--bg-card); border-radius: 32rpx 32rpx 0 0; z-index: 1000; transform: translateY(100%); transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; flex-direction: column; max-height: 80vh; }
.address-popup-container.show { transform: translateY(0); }
.popup-header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; font-size: 32rpx; font-weight: 700; color: var(--text-main); border-bottom: 2rpx solid var(--border); }
.close-btn { font-size: 40rpx; color: var(--text-muted); padding: 0 16rpx; margin-right: -16rpx; line-height: 1; }
.popup-body { flex: 1; min-height: 300rpx; max-height: 50vh; padding: 0 32rpx; }
.address-item { padding: 32rpx 0; border-bottom: 2rpx solid var(--border); display: flex; justify-content: space-between; align-items: center; }
.address-item:last-child { border-bottom: none; }
.addr-info { flex: 1; padding-right: 24rpx; }
.addr-detail-text { font-size: 30rpx; font-weight: 600; color: var(--text-main); margin-bottom: 8rpx; }
.check-icon { color: var(--brand-primary); font-size: 32rpx; font-weight: 700; }
.popup-footer { padding: 24rpx 32rpx; border-top: 2rpx solid var(--border); }
.btn-add-address { background: var(--brand-light); color: var(--brand-dark); border: 2rpx solid var(--brand-dark); border-radius: 44rpx; height: 88rpx; line-height: 84rpx; font-size: 30rpx; font-weight: 700; display: flex; justify-content: center; align-items: center; width: 100% !important; margin: 0; box-sizing: border-box; }
