page {
  --bg-app: #f5f6f7;
  --text-main: #1a1a1a;
  --text-sub: #666666;
  --text-muted: #999999;
  --border: #eeeeee;

  --brand-primary: #b8d060;
  --brand-dark: #92aa40;
  --brand-light: #f4f7e6;

  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);

  --brand-color: #92AA40;
  --success-color: #237b4b;
  --error-color: #b42318;
  --warning-color: #d97706;
  --info-color: #1677ff;
  --bg-card: #ffffff;
  --bg-card-alt: #fafaf8;
  --bg-dark: #1A1A1A;

  background: var(--bg-app);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
  box-sizing: border-box;
}

view, text, scroll-view, image, button, input {
  box-sizing: border-box;
}

/* 骨架屏 */
@keyframes skeleton-blink {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}
.skeleton-bg {
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 37%, #f2f2f2 63%);
  background-size: 400% 100%;
  animation: skeleton-blink 1.4s ease infinite;
}
.skeleton-text {
  height: 32rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}
.skeleton-img {
  border-radius: 16rpx;
}

/* 首页加载骨架屏（home 页引用，补全类定义以恢复闪烁动画） */
.skeleton-list { padding: 0; }
.skeleton-card {
  background: var(--bg-card);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.skeleton-header {
  width: 140rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}
.skeleton-body { display: flex; align-items: flex-start; }
.skeleton-badge {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.skeleton-lines { flex: 1; padding-top: 8rpx; }
.skeleton-line {
  height: 28rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}
.skeleton-line.short { width: 60%; }
.skeleton-card .skeleton-header,
.skeleton-card .skeleton-badge,
.skeleton-card .skeleton-line {
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 37%, #f2f2f2 63%);
  background-size: 400% 100%;
  animation: skeleton-blink 1.4s ease infinite;
}

/* 全局空状态 */
.global-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: var(--text-muted);
}
.global-empty-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}
.global-empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 16rpx;
}
.global-empty-desc {
  font-size: 26rpx;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

button, .btn-submit, .btn-checkout, .action-btn, .sub-btn, .btn-go-order, .btn-add-address, .list-item-btn {
  transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s;
}

button:active, .btn-submit:active, .btn-checkout:active, .action-btn:active, .sub-btn:active, .btn-go-order:active, .btn-add-address:active, .list-item-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.content { flex: 1; overflow-y: auto; position: relative; background: var(--bg-app); }

/* Navigation Bar Customization (from rider miniapp) */
.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.6);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.custom-nav-content {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.custom-nav-spacer {
  width: 100%;
  background: transparent;
}

.custom-nav-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.custom-nav-logo {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.08);
}

.custom-nav-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-main);
}

/* =========================================
    子页面通用组件
    ========================================= */

.subpage-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.6);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.subpage-nav-spacer {
  width: 100%;
  background: transparent;
}

.subpage-nav-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.subpage-nav-back {
  width: 68rpx;
  height: 68rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.subpage-nav-back:active {
  background: rgba(15, 23, 42, 0.06);
}

.subpage-nav-back-icon {
  display: inline-block;
  width: 22rpx;
  height: 22rpx;
  border-top: 5rpx solid var(--text-main, #0F172A);
  border-left: 5rpx solid var(--text-main, #0F172A);
  transform: rotate(-45deg);
  margin-left: 12rpx;
  border-top-left-radius: 3rpx;
}

.subpage-nav-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main);
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.subpage-nav-right {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
}

.subpage-nav-content {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.subpage {
  min-height: 100vh;
  background: var(--bg-card-alt);
  padding: 24rpx 24rpx 120rpx;
}

.subpage-card {
  background: var(--bg-card);
  border-radius: 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--border);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 40rpx;
}

.filter-chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  color: var(--text-sub);
  font-size: 24rpx;
  font-weight: 600;
}

.filter-chip.active {
  background: #000000;
  color: #ffffff;
  border-color: #000000;
}

.subpage-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.subpage-subtitle {
  font-size: 24rpx;
  color: var(--text-sub);
  line-height: 1.7;
}

.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.order-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.detail-line {
  font-size: 24rpx;
  color: var(--text-sub);
  line-height: 1.7;
  margin-top: 8rpx;
}

.empty-text {
  text-align: center;
  color: var(--text-muted);
  font-size: 24rpx;
  padding: 40rpx 0;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.status-pill.pending {
  background: #f4f7e6;
  color: var(--brand-color);
}

.status-pill.dispatching {
  background: #e8f3ff;
  color: var(--info-color);
}

.status-pill.delivered {
  background: #eef9f0;
  color: var(--success-color);
}

.status-pill.cancelled {
  background: #f6f6f6;
  color: var(--text-muted);
}

.status-pill-default {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--brand-light);
  color: var(--brand-color);
  border: 2rpx solid rgba(146, 170, 64, 0.3);
  border-radius: 12rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.sub-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  border: none;
  padding: 0 28rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.sub-btn::after {
  border: none;
}

.sub-btn.primary {
  background: var(--brand-primary);
  color: #111111;
}

.sub-btn.ghost {
  background: var(--bg-card);
  color: var(--text-main);
  border: 2rpx solid var(--border);
}

.inline-form-item {
  margin-top: 16rpx;
}

.inline-form-label {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-bottom: 8rpx;
}

.form-input {
  height: 84rpx;
  border-radius: 18rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-main);
}
.form-input::placeholder {
  color: var(--text-muted);
}

.switch-row {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.full-btn {
  width: 100%;
  margin-top: 28rpx;
}

.action-row {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.receipt-image {
  width: 100%;
  height: 320rpx;
  border-radius: 20rpx;
  background: #f3f3f3;
  margin-top: 16rpx;
}

.receipt-btn {
  width: 100%;
  margin-top: 20rpx;
}

.rider-note-line {
  font-weight: 600;
  color: var(--text-main);
}

.hero-inline {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.hero-inline-title {
  font-size: 22rpx;
  color: var(--brand-dark);
  font-weight: 700;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.hero-inline-main {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-main);
}

.hero-inline-side {
  font-size: 22rpx;
  color: var(--text-sub);
  font-weight: 600;
  padding-bottom: 6rpx;
}
