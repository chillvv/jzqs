.task-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e5e7eb;
  transition: all 0.3s ease;
}

.task-card.is-completed {
  opacity: 0.6;
  background: #f8fafc;
  border-color: #f1f5f9;
}

.task-card-highlight {
  border-color: #3b82f6;
  background: linear-gradient(180deg, #ffffff 0%, #eff6ff 100%);
  box-shadow: 0 6rpx 16rpx rgba(59, 130, 246, 0.12);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-sequence {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #eff6ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.task-status {
  display: flex;
  gap: 12rpx;
}

.task-address {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 16rpx;
}

.task-card.is-completed .task-address {
  background: #f1f5f9;
}

.address-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.address-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.5;
  flex: 1;
}

.task-customer {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  padding: 0 8rpx;
}

.customer-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #475569;
  margin-right: 16rpx;
}

.customer-phone {
  font-size: 28rpx;
  color: #475569;
}

.task-note {
  padding: 16rpx 20rpx;
  background: #fef3c7;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.note-label {
  font-size: 26rpx;
  color: #92400e;
  font-weight: 700;
}

.note-text {
  font-size: 26rpx;
  color: #92400e;
  font-weight: 600;
}

.task-actions {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f1f5f9;
}
