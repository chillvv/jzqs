<view class="task-card {{highlight ? 'task-card-highlight' : ''}} {{status === 'DELIVERED' ? 'is-completed' : ''}} {{className}}">
  <!-- 头部：序号和状态 -->
  <view class="task-header">
    <view class="task-sequence">{{sequence}}</view>
    <view class="task-status">
      <text class="tag {{statusClass}}">{{statusLabel}}</text>
      <text class="tag tag-gray">{{mealLabel}}</text>
    </view>
  </view>

  <!-- 地址信息 (提至客户信息之上，放大展示) -->
  <view class="task-address">
    <text class="address-icon">📍</text>
    <text class="address-text">{{deliveryAddress}}</text>
  </view>

  <!-- 客户信息 -->
  <view class="task-customer">
    <text class="customer-name">{{customerName}}</text>
    <text class="customer-phone" wx:if="{{showPhone}}">{{customerPhone}}</text>
  </view>

  <!-- 备注信息 -->
  <view class="task-note" wx:if="{{note && note !== '-'}}">
    <text class="note-label">备注：</text>
    <text class="note-text">{{note}}</text>
  </view>

  <!-- 操作按钮 -->
  <view class="task-actions" wx:if="{{showActions}}">
    <slot name="actions"></slot>
  </view>
</view>
