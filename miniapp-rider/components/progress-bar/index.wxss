.progress-bar-container {
  width: 100%;
}

.progress-bar-bg {
  width: 100%;
  position: relative;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  transition: width 0.3s ease;
}

.progress-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
}
