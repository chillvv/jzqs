<view class="progress-bar-container">
  <view 
    class="progress-bar-bg" 
    style="height: {{height}}; background-color: {{backgroundColor}}; border-radius: {{borderRadius}};"
  >
    <view 
      class="progress-bar-fill" 
      style="width: {{percentage}}%; background-color: {{color}}; transition: width {{duration}}ms ease; border-radius: {{borderRadius}};"
    ></view>
  </view>
  <view class="progress-text" wx:if="{{showText}}">
    {{current}} / {{total}} ({{percentage}}%)
  </view>
</view>
