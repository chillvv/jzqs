/* 队列卡片 - 紧凑版 */
.queue-card {
  display: flex;
  align-items: flex-start;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  position: relative;
  min-height: 100rpx;
}

/* 当前订单 - 高亮显示 */
.queue-card-current {
  background: linear-gradient(135deg, #e6f4ff 0%, #bae0ff 100%);
  border: 2rpx solid #1677ff;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.2);
  min-height: 180rpx;
}

/* 已送达订单 - 灰色淡化 */
.queue-card-delivered {
  opacity: 0.5;
  background: #fafafa;
  min-height: 80rpx;
}

.queue-card-delivered .queue-sequence {
  background: #d9d9d9;
  color: #8c8c8c;
}

.queue-card-delivered .customer-name {
  color: #8c8c8c;
  text-decoration: line-through;
}

/* 序号 */
.queue-sequence {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.3);
}

/* 内容区 */
.queue-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

/* 头部：客户名称和状态 */
.queue-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-width: 0;
}

.customer-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 地址（单行截断） */
.queue-address {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.4;
  white-space: normal;
  word-break: break-all;
}

/* 元信息：餐期和备注 */
.queue-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.meal-tag {
  flex-shrink: 0;
}

.queue-note {
  font-size: 22rpx;
  color: #999999;
  flex: 1;
  min-width: 0;
  white-space: normal;
  word-break: break-all;
}

/* 快捷操作按钮 */
.queue-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(22, 119, 255, 0.15);
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 8rpx;
  padding: 12rpx 8rpx;
  border: 1rpx solid #d9d9d9;
  font-size: 22rpx;
  line-height: 1.2;
  transition: all 0.2s ease;
}

.action-btn::after {
  border: none;
}

.action-btn-hover {
  background: #f5f5f5;
  transform: scale(0.95);
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666666;
  font-weight: 500;
}

/* 导航按钮 */
.action-navigate {
  border-color: #1677ff;
}

.action-navigate .action-text {
  color: #1677ff;
}

/* 电话按钮 */
.action-call {
  border-color: #52c41a;
}

.action-call .action-text {
  color: #52c41a;
}

/* 完成按钮 */
.action-done {
  border-color: #faad14;
}

.action-done .action-text {
  color: #faad14;
}

/* 当前订单的按钮样式增强 */
.queue-card-current .action-btn {
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
}
