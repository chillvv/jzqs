.container {
  padding: 20px;
}

.header {
  margin-bottom: 20px;
}

.title {
  font-size: 20px;
  font-weight: bold;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}

.logs {
  background: #f5f5f5;
  padding: 15px;
  border-radius: 8px;
  min-height: 200px;
}

.log-item {
  font-size: 12px;
  line-height: 1.6;
  margin-bottom: 5px;
  font-family: monospace;
}
