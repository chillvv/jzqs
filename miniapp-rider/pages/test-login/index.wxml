<view class="container">
  <view class="header">
    <text class="title">登录测试工具</text>
    <text class="subtitle">API: {{apiBaseUrl}}</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" type="text" value="{{name}}" bindinput="onNameInput" />
    </view>
  </view>

  <view class="actions">
    <button class="btn" bindtap="testWxLogin">1. 测试微信登录</button>
    <button class="btn" bindtap="testRegister">2. 测试注册</button>
    <button class="btn" bindtap="testPhoneLogin">3. 测试手机号登录</button>
    <button class="btn" bindtap="testVerifyToken">4. 测试 Token 验证</button>
    <button class="btn btn-danger" bindtap="clearAuth">清除登录态</button>
  </view>

  <view class="logs">
    <view class="logs-header">
      <text class="logs-title">日志</text>
      <text class="logs-clear" bindtap="clearLogs">清除</text>
    </view>
    <view class="log-item" wx:for="{{logs}}" wx:key="index">
      {{item}}
    </view>
  </view>
</view>
