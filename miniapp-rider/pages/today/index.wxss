/**
 * 今日任务页面样式 - 完全按照HTML设计的小而美风格
 */

.today-page {
  min-height: 100vh;
  background: #F5F5F7;
  padding-bottom: 160rpx;
}

/* 主内容区域 */
.today-content {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* Hero 卡片 */
.hero-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  padding: 32rpx;
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(240, 237, 239, 0.5);
}

.hero-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #0050CB 0%, #0066FF 100%);
}

.hero-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.hero-title {
  display: flex;
  flex-direction: column;
}

.hero-greeting {
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #666666;
  margin-bottom: 4rpx;
}

.hero-name {
  font-size: 48rpx;
  line-height: 64rpx;
  font-weight: 700;
  color: #1B1B1D;
  letter-spacing: -0.02em;
}

.hero-date {
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 500;
  color: #666666;
  text-align: right;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-top: 8rpx;
}

.stat-box {
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 2rpx solid #F0EDEF;
}

.stat-value {
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 600;
  color: #1B1B1D;
  margin-bottom: 4rpx;
}

.stat-value.primary {
  color: #0050CB;
}

.stat-value.success {
  color: #34C759;
}

.stat-value.warning {
  color: #FF9500;
}

.stat-label {
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  color: #666666;
}

/* 批次列表 */
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: normal;
  color: #10b981;
  background-color: #ecfdf5;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(16, 185, 129, 0.14);
}

.date-badge-arrow {
  font-size: 18rpx;
  opacity: 0.7;
}

.batch-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.batch-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  padding: 24rpx;
  position: relative;
  overflow: hidden;
  border: 2rpx solid #F0EDEF;
}

.batch-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: #0050CB;
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-left: 16rpx;
  margin-bottom: 16rpx;
}

.batch-title {
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 600;
  color: #1B1B1D;
}

.batch-status {
  background: rgba(0, 80, 203, 0.1);
  color: #0050CB;
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.batch-status.completed {
  background: rgba(52, 199, 89, 0.1);
  color: #006825;
}

.batch-info {
  display: flex;
  gap: 32rpx;
  padding-left: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #F0EDEF;
}

.batch-info-item {
  display: flex;
  flex-direction: column;
}

.batch-info-label {
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 4rpx;
}

.batch-info-value {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
  color: #1B1B1D;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
  text-align: center;
}

.empty-icon {
  font-size: 160rpx;
  opacity: 0.3;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  font-weight: 500;
}

.date-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.32);
  z-index: 1000;
}

.date-picker-sheet {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(130rpx + env(safe-area-inset-bottom) + 24rpx);
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  max-height: calc(100vh - 240rpx - env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.18);
  z-index: 1001;
}

.date-picker-sheet__header {
  margin-bottom: 20rpx;
}

.date-picker-sheet__title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.date-picker-sheet__subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.date-picker-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.date-picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid transparent;
}

.date-picker-option--active {
  background: #ecfdf5;
  border-color: rgba(16, 185, 129, 0.22);
}

.date-picker-option__label {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.date-picker-option__value {
  font-size: 26rpx;
  color: #10b981;
}
