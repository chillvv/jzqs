/**
 * 今日任务页面样式 - 完全按照HTML设计的小而美风格
 */

.today-page {
  min-height: 100vh;
  background: #F5F5F7;
  padding-bottom: 160rpx;
}

/* 主内容区域 */
.today-content {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* Hero 卡片 */
.hero-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  padding: 32rpx;
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(240, 237, 239, 0.5);
}

.hero-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #0050CB 0%, #0066FF 100%);
}

.hero-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.hero-title {
  display: flex;
  flex-direction: column;
}

.hero-greeting {
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #666666;
  margin-bottom: 4rpx;
}

.hero-name {
  font-size: 48rpx;
  line-height: 64rpx;
  font-weight: 700;
  color: #1B1B1D;
  letter-spacing: -0.02em;
}

.hero-date {
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 500;
  color: #666666;
  text-align: right;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-top: 8rpx;
}

.stat-box {
  background: #F5F5F7;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 2rpx solid #F0EDEF;
}

.stat-value {
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 600;
  color: #1B1B1D;
  margin-bottom: 4rpx;
}

.stat-value.primary {
  color: #0050CB;
}

.stat-value.success {
  color: #34C759;
}

.stat-value.warning {
  color: #FF9500;
}

.stat-label {
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  color: #666666;
}

/* 批次列表 */
.batch-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.batch-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  padding: 24rpx;
  position: relative;
  overflow: hidden;
  border: 2rpx solid #F0EDEF;
}

.batch-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: #0050CB;
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-left: 16rpx;
  margin-bottom: 16rpx;
}

.batch-title {
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 600;
  color: #1B1B1D;
}

.batch-status {
  background: rgba(0, 80, 203, 0.1);
  color: #0050CB;
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.batch-status.completed {
  background: rgba(52, 199, 89, 0.1);
  color: #006825;
}

.batch-info {
  display: flex;
  gap: 32rpx;
  padding-left: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #F0EDEF;
}

.batch-info-item {
  display: flex;
  flex-direction: column;
}

.batch-info-label {
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 4rpx;
}

.batch-info-value {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
  color: #1B1B1D;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
  text-align: center;
}

.empty-icon {
  font-size: 160rpx;
  opacity: 0.3;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  font-weight: 500;
}
