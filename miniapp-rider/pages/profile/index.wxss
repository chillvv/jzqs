page {
  background: #F5F5F5;
  --text-main: #1A1A1A;
  --text-sub: #666666;
  --text-muted: #999999;
  --brand-primary: #2563EB;
  --brand-dark: #1D4ED8;
  --brand-light: #EFF6FF;
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
  --border: #eeeeee;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom) + 20rpx);
  background: #FAFAF8;
}

/* Header */
.header-bar {
  position: sticky;
  top: 0;
  z-index: 40;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.6);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: var(--text-main);
}

.header-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
}

.header-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
  letter-spacing: -0.02em;
}

#tab-profile { min-height: 100vh; padding-bottom: calc(136rpx + env(safe-area-inset-bottom)); background: #FAFAF8; }
.profile-header { padding: 32rpx 40rpx 16rpx; display: flex; align-items: center; gap: 32rpx; }
.vip-card { margin: 24rpx; border-radius: 24rpx; padding: 36rpx; background: linear-gradient(135deg, #3B82F6 0%, #1E40AF 100%); color: #FFFFFF; box-shadow: 0 12px 32px rgba(37, 99, 235, 0.24); position: relative; overflow: hidden; border: 1px solid rgba(255, 255, 255, 0.15); }
.vip-card::after { content: ''; position: absolute; right: -50rpx; top: -50rpx; width: 250rpx; height: 250rpx; background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%); border-radius: 50%; }
.vip-card::before { content: ''; position: absolute; left: -80rpx; bottom: -80rpx; width: 300rpx; height: 300rpx; background: radial-gradient(circle, rgba(96, 165, 250, 0.2) 0%, transparent 70%); border-radius: 50%; }
.vip-title { font-size: 24rpx; font-weight: 600; color: rgba(255, 255, 255, 0.7); margin-bottom: 12rpx; }
.vip-balance { display: flex; align-items: baseline; gap: 8rpx; margin-bottom: 20rpx; }
.vip-balance .num { font-size: 64rpx; font-weight: 800; color: #fff; line-height: 1; }
.vip-balance .unit { font-size: 24rpx; font-weight: 600; }
.vip-footer { display: flex; justify-content: space-between; align-items: center; border-top: 2rpx solid rgba(255, 255, 255, 0.1); padding-top: 20rpx; }
.vip-status { font-size: 22rpx; display: flex; align-items: center; gap: 12rpx; }
.status-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #94A3B8; }
.status-active { background: #10B981; box-shadow: 0 0 8px rgba(16, 185, 129, 0.6); }
.status-disabled { background: #EF4444; }
.menu-group { background: #FFFFFF; border-radius: 24rpx; margin: 0 24rpx 32rpx; padding: 0; box-shadow: var(--shadow-sm); }
.list-item { padding: 32rpx; display: flex; justify-content: space-between; align-items: center; border-bottom: 2rpx solid var(--border); font-size: 30rpx; font-weight: 600; color: var(--text-main); }
.list-item:last-child { border-bottom: none; }
.list-icon-wrap { display: flex; align-items: center; gap: 24rpx; }
.list-copy { flex: 1; }
.list-title { font-size: 30rpx; font-weight: 700; color: var(--text-main); }
.list-desc { margin-top: 8rpx; font-size: 22rpx; line-height: 1.6; color: var(--text-sub); }
.list-item-btn {
  width: 100% !important;
  background: transparent !important;
  margin: 0 !important;
  border-radius: 0 !important;
  text-align: left !important;
  line-height: normal !important;
  padding: 32rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  color: var(--text-main) !important;
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
}
.list-item-btn::after {
  border: none;
}

.logout-section {
  padding: 40rpx;
  margin-top: 20rpx;
}

.btn-logout {
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  line-height: 1;
  text-align: center;
}

.btn-logout::after {
  border: none;
}

/* 访客态卡片 */
.guest-card { background: #FFFFFF; border-radius: 32rpx; margin: 0 24rpx 32rpx; padding: 48rpx 40rpx; box-shadow: var(--shadow-sm); }
.guest-title { font-size: 40rpx; font-weight: 800; color: var(--text-main); margin-bottom: 12rpx; text-align: center; }
.guest-subtitle { font-size: 26rpx; color: var(--text-sub); text-align: center; margin-bottom: 48rpx; }
.benefit-list { margin-bottom: 48rpx; }
.benefit-item { margin-bottom: 24rpx; }
.benefit-item:last-child { margin-bottom: 0; }
.benefit-title { font-size: 30rpx; font-weight: 700; color: var(--text-main); margin-bottom: 8rpx; display: flex; align-items: center; }
.benefit-title .dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--brand-primary); margin-right: 16rpx; }
.benefit-desc { font-size: 26rpx; color: var(--text-sub); padding-left: 28rpx; line-height: 1.6; }
.step-guide { background: #F9F9F9; border-radius: 20rpx; padding: 32rpx; margin-bottom: 48rpx; }
.step-title { font-size: 28rpx; font-weight: 700; color: var(--text-main); margin-bottom: 24rpx; text-align: center; }
.step-list { display: flex; flex-direction: column; gap: 24rpx; }
.step-item { display: flex; align-items: flex-start; gap: 16rpx; }
.step-num { width: 36rpx; height: 36rpx; border-radius: 50%; background: var(--brand-light); color: var(--brand-dark); font-size: 22rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 4rpx; }
.step-text { font-size: 26rpx; color: var(--text-sub); line-height: 1.6; flex: 1; }
.btn-guest-primary { background: var(--brand-primary); color: #FFF; border: none; height: 88rpx; line-height: 88rpx; border-radius: 44rpx; font-size: 32rpx; font-weight: 700; width: 100%; }
.btn-guest-primary::after { border: none; }

.profile-name {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
}

.profile-meta {
  flex: 1;
}

.profile-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-sub);
}

.profile-badge {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.profile-guest-action {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: var(--brand-light);
  color: var(--brand-dark);
  font-size: 24rpx;
  font-weight: 700;
  gap: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.2);
  border: 2rpx solid rgba(37, 99, 235, 0.4);
}

.profile-guest-action .arrow {
  font-family: Arial, sans-serif;
  font-weight: normal;
  color: #999999;
}

.profile-badge.member {
  background: var(--brand-light);
  color: var(--brand-dark);
}


/* 完善信息弹窗 UI */
.auth-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.auth-popup-mask.show {
  visibility: visible;
  opacity: 1;
}

.auth-popup-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F5F6F7;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  padding-bottom: calc(env(safe-area-inset-bottom) + 160rpx);
}

.auth-popup-container.show {
  transform: translateY(0);
}

.auth-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx 20rpx;
}

.auth-popup-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1A1A1A;
}

.auth-popup-close {
  font-size: 44rpx;
  color: #999;
  line-height: 1;
  padding: 10rpx;
  font-weight: 300;
}

.auth-popup-body {
  padding: 0 40rpx 72rpx;
  display: flex;
  flex-direction: column;
}

.auth-form-group {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  border: 1px solid #EEEEEE;
}

.auth-form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #EEEEEE;
  min-height: 104rpx;
}

.auth-form-item.border-none {
  border-bottom: none;
  display: block;
  padding: 0;
  min-height: 0;
}

.auth-form-label {
  width: 120rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 600;
  flex-shrink: 0;
}

.auth-avatar-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  background: transparent;
  padding: 0;
  margin: 0;
  text-align: right;
  line-height: normal;
  min-height: 92rpx;
}

.auth-avatar-btn::after {
  border: none;
}

.auth-avatar-img {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #F5F6F7;
  border: 2rpx solid #EEEEEE;
}

.auth-avatar-arrow {
  font-size: 44rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
  font-family: Arial, sans-serif;
}

.auth-form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  text-align: left;
  padding-left: 24rpx;
  min-height: 52rpx;
  line-height: 52rpx;
}

.auth-form-input::placeholder {
  color: #999999;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1px solid #eeeeee;
  min-height: 120rpx;
}

.label {
  width: 128rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  flex-shrink: 0;
}

.phone-input {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: #333333;
  padding-right: 24rpx;
  min-height: 52rpx;
  line-height: 52rpx;
}

.ph-color {
  color: #999999;
}

.quick-get-btn {
  background: transparent;
  margin: 0;
  outline: none;
  border: 2rpx solid #b3cf64;
  color: #b3cf64;
  font-size: 24rpx;
  font-weight: 600;
  height: 58rpx;
  line-height: 54rpx;
  border-radius: 29rpx;
  padding: 0 24rpx;
  flex-shrink: 0;
}

.quick-get-btn::after {
  border: none;
}

.phone-auth-panel {
  padding: 32rpx 0 36rpx;
}

.phone-auth-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.phone-auth-value {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #999999;
}

.phone-auth-value.authorized {
  color: var(--brand-dark);
  font-weight: 700;
}

.phone-manual-input {
  margin-top: 20rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  background: #F5F6F7;
  border-radius: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #EEEEEE;
}

.phone-manual-input::placeholder {
  color: #BBBBBB;
  font-size: 28rpx;
}

.phone-manual-input:focus {
  border-color: var(--brand-primary);
}

.phone-auth-hint {
  margin: 0 0 24rpx;
  font-size: 24rpx;
  color: #999999;
}

.auth-submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: var(--brand-primary);
  color: #FFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(37, 99, 235, 0.25);
  margin: 0 auto;
  display: block;
  text-align: center;
  padding: 0;
}

.auth-submit-btn::after {
  border: none;
}

/* 禁用状态 */
.auth-submit-btn[disabled] {
  opacity: 0.6;
}

.auth-entry-btn {
  width: 320rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
}

/* 微信快捷登录 (次要按钮) */
.btn-wechat-alt {
  background: #07C160;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  margin: 0 auto;
  margin: 20rpx auto 0;
}

.btn-wechat-alt::after { border: none; }
.btn-wechat-alt:active { opacity: 0.8; }

/* 分隔线 */
.or-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 64rpx 0 40rpx;
  color: #AAAAAA;
  font-size: 24rpx;
  gap: 24rpx;
}

.or-divider::before,
.or-divider::after {
  content: '';
  width: 60rpx;
  height: 1px;
  background: #EEEEEE;
}

/* 表单项 */
.auth-form-item-last {
  border-bottom: none !important;
}
