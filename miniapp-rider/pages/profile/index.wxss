page {
  background: #F5F5F5;
  --text-main: #1A1A1A;
  --text-sub: #666666;
  --text-muted: #999999;
  --brand-dark: #1D4ED8;
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04);
  --border: #eeeeee;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom) + 20rpx);
  background: #FAFAF8;
}

/* Header */
.header-bar {
  position: sticky;
  top: 0;
  z-index: 40;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.6);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: var(--text-main);
}

.header-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
}

.header-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
  letter-spacing: -0.02em;
}

#tab-profile { min-height: 100vh; padding-bottom: calc(136rpx + env(safe-area-inset-bottom)); background: #FAFAF8; }
.profile-header { padding: 32rpx 40rpx 16rpx; display: flex; align-items: center; gap: 32rpx; }
.vip-card { margin: 24rpx; border-radius: 24rpx; padding: 36rpx; background: linear-gradient(135deg, #3B82F6 0%, #1E40AF 100%); color: #FFFFFF; box-shadow: 0 12px 32px rgba(37, 99, 235, 0.24); position: relative; overflow: hidden; border: 1px solid rgba(255, 255, 255, 0.15); }
.vip-card::after { content: ''; position: absolute; right: -50rpx; top: -50rpx; width: 250rpx; height: 250rpx; background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%); border-radius: 50%; }
.vip-card::before { content: ''; position: absolute; left: -80rpx; bottom: -80rpx; width: 300rpx; height: 300rpx; background: radial-gradient(circle, rgba(96, 165, 250, 0.2) 0%, transparent 70%); border-radius: 50%; }

/* Sweep Animation */
.vip-card::after, .vip-card::before { z-index: 1; }
.vip-card-sweep {
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  transform: skewX(-20deg);
  animation: sweep 4s infinite cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 2;
  pointer-events: none;
}
@keyframes sweep {
  0% { left: -100%; }
  20% { left: 200%; }
  100% { left: 200%; }
}

.vip-title { font-size: 24rpx; font-weight: 600; color: rgba(255, 255, 255, 0.7); margin-bottom: 12rpx; position: relative; z-index: 3; }
.vip-balance { display: flex; align-items: baseline; gap: 8rpx; margin-bottom: 20rpx; position: relative; z-index: 3; }
.vip-balance .num { font-family: 'Courier New', 'SF Mono', Monaco, monospace; font-size: 72rpx; font-weight: 800; color: #fff; line-height: 1; letter-spacing: 2rpx; }
.vip-balance .unit { font-size: 24rpx; font-weight: 600; }
.vip-footer { display: flex; justify-content: space-between; align-items: center; border-top: 2rpx solid rgba(255, 255, 255, 0.1); padding-top: 20rpx; position: relative; z-index: 3; }
.vip-status { font-size: 22rpx; display: flex; align-items: center; gap: 12rpx; }
.status-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--outline); }
.status-active { background: var(--success); box-shadow: 0 0 8px rgba(16, 185, 129, 0.6); }
.status-disabled { background: var(--error); }
.menu-group { background: var(--surface); border-radius: 24rpx; margin: 0 24rpx 32rpx; padding: 0; box-shadow: var(--shadow-sm); }
.list-item { padding: 32rpx; display: flex; justify-content: space-between; align-items: center; border-bottom: 2rpx solid var(--border); font-size: 30rpx; font-weight: 600; color: var(--text-main); }
.list-item:last-child { border-bottom: none; }
.list-icon-wrap { display: flex; align-items: center; gap: 24rpx; }
.list-icon { font-size: 36rpx; line-height: 1; }
.list-copy { flex: 1; min-width: 0; }
.list-title { font-size: 30rpx; font-weight: 700; color: var(--text-main); word-break: break-all; }
.list-desc { margin-top: 8rpx; font-size: 22rpx; line-height: 1.6; color: var(--text-sub); word-break: break-all; }
.list-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  font-size: 32rpx;
  line-height: 1;
  color: #bbbbbb;
  font-family: Arial, sans-serif;
}
.auth-form-hint,
.phone-auth-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-sub);
  word-break: break-all;
}
.list-item-btn {
  width: 100% !important;
  background: transparent !important;
  margin: 0 !important;
  border-radius: 0 !important;
  text-align: left !important;
  line-height: normal !important;
  padding: 32rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  color: var(--text-main) !important;
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
}
.list-item-btn::after {
  border: none;
}

.logout-section {
  padding: 40rpx;
  margin-top: 20rpx;
}

.btn-logout {
  width: 100% !important;
  background: var(--surface);
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 40rpx;
  font-size: 28rpx;
  height: 88rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.btn-logout::after {
  border: none;
}

/* 访客态卡片 */
.guest-card { background: var(--surface); border-radius: 32rpx; margin: 0 24rpx 32rpx; padding: 48rpx 40rpx; box-shadow: var(--shadow-sm); }
.guest-title { font-size: 40rpx; font-weight: 800; color: var(--text-main); margin-bottom: 12rpx; text-align: center; }
.guest-subtitle { font-size: 26rpx; color: var(--text-sub); text-align: center; margin-bottom: 48rpx; }
.benefit-list { margin-bottom: 48rpx; }
.benefit-item { margin-bottom: 24rpx; }
.benefit-item:last-child { margin-bottom: 0; }
.benefit-title { font-size: 30rpx; font-weight: 700; color: var(--text-main); margin-bottom: 8rpx; display: flex; align-items: center; }
.benefit-title .dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--brand-primary); margin-right: 16rpx; }
.benefit-desc { font-size: 26rpx; color: var(--text-sub); padding-left: 28rpx; line-height: 1.6; }
.step-guide { background: #F9F9F9; border-radius: 20rpx; padding: 32rpx; margin-bottom: 48rpx; }
.step-title { font-size: 28rpx; font-weight: 700; color: var(--text-main); margin-bottom: 24rpx; text-align: center; }
.step-list { display: flex; flex-direction: column; gap: 24rpx; }
.step-item { display: flex; align-items: flex-start; gap: 16rpx; }
.step-num { width: 36rpx; height: 36rpx; border-radius: 50%; background: var(--primary-container); color: var(--brand-dark); font-size: 22rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 4rpx; }
.step-text { font-size: 26rpx; color: var(--text-sub); line-height: 1.6; flex: 1; }
.btn-guest-primary { background: var(--brand-primary); color: #FFF; border: none; height: 88rpx; line-height: 88rpx; border-radius: 44rpx; font-size: 32rpx; font-weight: 700; width: 100%; }
.btn-guest-primary::after { border: none; }

.profile-name {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
  word-break: break-all;
}

.profile-meta {
  flex: 1;
  min-width: 0;
}

.profile-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-sub);
  word-break: break-all;
}

.profile-badge {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.profile-guest-action {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: var(--primary-container);
  color: var(--brand-dark);
  font-size: 24rpx;
  font-weight: 700;
  gap: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.2);
  border: 2rpx solid rgba(37, 99, 235, 0.4);
}

.profile-guest-action .arrow {
  font-family: Arial, sans-serif;
  font-weight: normal;
  color: #999999;
}

.profile-badge.member {
  background: var(--primary-container);
  color: var(--brand-dark);
}


/* 完善信息弹窗 UI */
.auth-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.auth-popup-mask.show {
  visibility: visible;
  opacity: 1;
}

.auth-popup-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F5F6F7;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  max-height: 86vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.auth-popup-container.show {
  transform: translateY(0);
}

.auth-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx 20rpx;
}

.auth-popup-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1A1A1A;
}

.auth-popup-close {
  font-size: 44rpx;
  color: #999;
  line-height: 1;
  padding: 10rpx;
  font-weight: 300;
}

.auth-popup-body {
  flex: 1;
  min-height: 0;
  padding: 0 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.auth-popup-footer {
  flex-shrink: 0;
  padding: 0 40rpx calc(env(safe-area-inset-bottom) + 32rpx);
  background: linear-gradient(180deg, rgba(247, 248, 250, 0) 0%, #f7f8fa 20%);
  overflow: visible;
}

.auth-popup-agreement-stack {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.auth-popup-copy {
  margin-bottom: 24rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #666666;
}

.auth-agreement {
  margin-bottom: 28rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: var(--surface);
  border: 1rpx solid #eeeeee;
}

.auth-agreement-label {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  color: #4b5563;
  line-height: 1.7;
}

.auth-agreement-text {
  font-size: 24rpx;
}

.auth-agreement-link {
  font-size: 24rpx;
  color: var(--brand-color);
  font-weight: 700;
}

.auth-form-group {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  border: 1px solid #EEEEEE;
}

.auth-form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid #EEEEEE;
  min-height: 104rpx;
}

.auth-form-item.border-none {
  border-bottom: none;
  display: block;
  padding: 0;
  min-height: 0;
}

.auth-form-label {
  width: 120rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 600;
  flex-shrink: 0;
}

.auth-avatar-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  background: transparent;
  padding: 0;
  margin: 0;
  text-align: right;
  line-height: normal;
  min-height: 92rpx;
}

.auth-avatar-btn::after {
  border: none;
}

.auth-avatar-img {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #F5F6F7;
  border: 2rpx solid #EEEEEE;
}

.auth-avatar-arrow {
  font-size: 44rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
  font-family: Arial, sans-serif;
}

.auth-form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  text-align: left;
  padding-left: 24rpx;
  min-height: 52rpx;
  line-height: 52rpx;
}

.auth-form-input::placeholder {
  color: #999999;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1px solid #eeeeee;
  min-height: 120rpx;
}

.label {
  width: 128rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  flex-shrink: 0;
}

.phone-input {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: #333333;
  padding-right: 24rpx;
  min-height: 52rpx;
  line-height: 52rpx;
}

.ph-color {
  color: #999999;
}

.quick-get-btn {
  background: transparent;
  margin: 0;
  outline: none;
  border: 2rpx solid #b3cf64;
  color: #b3cf64;
  font-size: 24rpx;
  font-weight: 600;
  height: 58rpx;
  line-height: 54rpx;
  border-radius: 29rpx;
  padding: 0 24rpx;
  flex-shrink: 0;
}

.quick-get-btn::after {
  border: none;
}

.phone-auth-panel {
  padding: 32rpx 0 36rpx;
}

.phone-auth-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.phone-auth-value {
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #999999;
}

.phone-auth-value.authorized {
  color: var(--brand-dark);
  font-weight: 700;
}

.phone-manual-input {
  margin-top: 20rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  background: #F5F6F7;
  border-radius: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #EEEEEE;
}

.phone-manual-input::placeholder {
  color: #BBBBBB;
  font-size: 28rpx;
}

.phone-manual-input:focus {
  border-color: var(--brand-primary);
}

.phone-auth-hint {
  margin: 0 0 24rpx;
  font-size: 24rpx;
  color: #999999;
}

.auth-submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  background: var(--brand-primary);
  color: #FFF;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(37, 99, 235, 0.25);
  margin: 0 auto;
  display: block;
  text-align: center;
  padding: 0;
}

.auth-submit-btn::after {
  border: none;
}

/* 禁用状态 */
.auth-submit-btn[disabled] {
  opacity: 0.6;
}

.auth-entry-btn {
  width: 320rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
}

.auth-dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1002;
}

.auth-dialog {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 1003;
  background: var(--surface);
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.18);
}

.auth-dialog-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.auth-dialog-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #666666;
}

.auth-dialog-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.auth-dialog-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 0;
}

.auth-dialog-btn::after {
  border: none;
}

.auth-dialog-btn-secondary {
  background: #f3f4f6;
  color: #374151;
}

.auth-dialog-btn-primary {
  background: var(--brand-primary);
  color: #ffffff;
}

/* Auth popup refresh */
.auth-popup-container {
  background: #f7f8fa;
  box-shadow: 0 -16rpx 48rpx rgba(15, 23, 42, 0.12);
}

.auth-popup-body {
  gap: 20rpx;
}

.auth-form-group {
  margin-bottom: 8rpx;
  box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.04);
}

.auth-entry-btn {
  width: 320rpx !important;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
}

.btn-wechat-alt {
  margin: 0 auto;
  box-shadow: 0 10rpx 24rpx rgba(7, 193, 96, 0.18);
}

.auth-submit-btn {
  margin: 0 auto;
  box-shadow: 0 10rpx 24rpx rgba(37, 99, 235, 0.16);
}

.auth-agreement-bar {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 8rpx 0;
  border-top: 1rpx solid rgba(203, 213, 225, 0.65);
}

.auth-agreement-copy-line {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.7;
  color: #6b7280;
}

.auth-agreement-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  margin-top: 2rpx;
  border-radius: 50%;
  border: 2rpx solid var(--surface-container-highest);
  background: var(--surface);
  box-sizing: border-box;
  flex-shrink: 0;
}

.auth-agreement-icon.checked {
  border-color: var(--brand-primary);
  background: var(--brand-primary);
}

.auth-agreement-icon-mark {
  font-size: 20rpx;
  color: #ffffff;
  line-height: 1;
}

.auth-agreement-sheet {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  margin: 0 8rpx;
  padding: 0 32rpx;
  background: var(--surface);
  border-radius: 28rpx 28rpx 0 0;
  box-shadow: 0 -10rpx 28rpx rgba(15, 23, 42, 0.12);
  transform: translateY(12rpx);
  transition: max-height 0.28s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.22s ease, transform 0.28s cubic-bezier(0.2, 0.8, 0.2, 1), padding 0.28s ease, margin-bottom 0.28s ease;
}

.auth-agreement-sheet.show {
  max-height: 720rpx;
  opacity: 1;
  margin-bottom: 12rpx;
  padding: 20rpx 32rpx 28rpx;
  transform: translateY(0);
}

.auth-agreement-sheet-handle {
  width: 88rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #d1d5db;
}

.auth-agreement-sheet-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
  text-align: center;
}

.auth-agreement-sheet-copy {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
  text-align: center;
}

.auth-agreement-sheet-link-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: var(--surface-container-low);
}

.auth-agreement-sheet-link-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.auth-agreement-sheet-link-arrow {
  font-size: 32rpx;
  color: var(--outline);
  font-family: Arial, sans-serif;
}

.auth-agreement-sheet-check {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 28rpx;
  padding: 8rpx 4rpx;
}

.auth-agreement-sheet-check-text {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.7;
  color: #374151;
}

.auth-agreement-sheet-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.auth-agreement-sheet-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.auth-agreement-sheet-btn::after {
  border: none;
}

.auth-agreement-sheet-btn-secondary {
  background: #eef2f7;
  color: #4b5563;
}

.auth-agreement-sheet-btn-primary {
  background: var(--brand-primary);
  color: #ffffff;
}

/* 微信快捷登录 (次要按钮) */
.btn-wechat-alt {
  background: #07C160;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  margin: 0 auto;
  margin: 20rpx auto 0;
}

.btn-wechat-alt::after { border: none; }
.btn-wechat-alt:active { opacity: 0.8; }

/* 分隔线 */
.or-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 64rpx 0 40rpx;
  color: #AAAAAA;
  font-size: 24rpx;
  gap: 24rpx;
}

.or-divider::before,
.or-divider::after {
  content: '';
  width: 60rpx;
  height: 1px;
  background: #EEEEEE;
}

/* 表单项 */
.auth-form-item-last {
  border-bottom: none !important;
}

/* 协议二次确认弹窗（底部弹出样式） */
.auth-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 10000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.auth-dialog-mask.show {
  visibility: visible;
  opacity: 1;
}

.auth-dialog {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 10001;
  padding: 48rpx 40rpx calc(env(safe-area-inset-bottom) + 40rpx);
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.auth-dialog.show {
  transform: translateY(0);
}

.auth-dialog-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #111111;
  text-align: center;
  margin-bottom: 24rpx;
}

.auth-dialog-copy {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666666;
  text-align: center;
  margin-bottom: 48rpx;
}

.auth-dialog-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.auth-dialog-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  margin: 0;
  padding: 0;
}

.auth-dialog-btn::after {
  border: none;
}

.auth-dialog-btn-secondary {
  background: #f5f5f5;
  color: #666666;
}

.auth-dialog-btn-primary {
  background: var(--brand-primary);
  color: #ffffff;
}
