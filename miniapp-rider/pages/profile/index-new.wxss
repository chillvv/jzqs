/* 骑手小程序 - 个人中心样式（极简重构版） */

.profile-page {
  min-height: 100vh;
  background: #fcf8fb;
  padding: 60rpx 32rpx;
}

/* 未登录状态 */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 60rpx;
}

.empty-icon {
  font-size: 160rpx;
  margin-bottom: 60rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1b1b1d;
  margin-bottom: 80rpx;
}

.btn-primary {
  padding: 28rpx 120rpx;
  background: linear-gradient(135deg, #0050cb 0%, #0066ff 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

/* 已登录状态 */
.logged-in {
  max-width: 600rpx;
  margin: 0 auto;
}

/* 个人信息卡片 */
.profile-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
  margin-bottom: 60rpx;
}

.profile-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #1b1b1d;
  margin-bottom: 16rpx;
}

.profile-phone {
  font-size: 32rpx;
  color: #727687;
}

.status-badge {
  display: inline-block;
  margin-top: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-badge.pending {
  background: #FFF3E0;
  color: #FF9500;
}

/* 退出登录按钮 */
.btn-logout {
  width: 100%;
  padding: 28rpx;
  background: #ffffff;
  color: #ba1a1a;
  border: 4rpx solid #ba1a1a;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 登录弹窗 */
.auth-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: none;
  align-items: flex-end;
  z-index: 1000;
}

.auth-modal.show {
  display: flex;
}

.auth-modal-content {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.auth-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.auth-modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1b1b1d;
}

.auth-modal-close {
  font-size: 60rpx;
  color: #727687;
  line-height: 1;
}

.auth-modal-body {
  padding: 0;
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
  position: relative;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1b1b1d;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 28rpx 24rpx;
  border: 2rpx solid #c2c6d8;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #1b1b1d;
}

.form-input:focus {
  border-color: #0050cb;
}

.btn-get-phone {
  position: absolute;
  right: 16rpx;
  top: 72rpx;
  padding: 16rpx 24rpx;
  background: #f0edef;
  color: #0050cb;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: none;
}

/* 协议 */
.agreement {
  margin: 32rpx 0;
}

.agreement-label {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #727687;
}

.agreement-label checkbox {
  margin-right: 12rpx;
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #0050cb 0%, #0066ff 100%);
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: 48rpx;
}

.btn-submit[loading] {
  opacity: 0.7;
}
