/**
 * 个人中心页面样式 - 完全按照HTML设计的小而美风格
 */

.rider-profile-page {
  min-height: 100vh;
  background: #F5F5F7;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* 标题 */
.section-title {
  font-size: 48rpx;
  line-height: 64rpx;
  font-weight: 700;
  color: #1B1B1D;
  margin-bottom: 24rpx;
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(240, 237, 239, 0.5);
}

.card-title {
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 600;
  color: #1B1B1D;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #F0EDEF;
}

/* 个人身份卡片 */
.profile-header-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  padding: 32rpx;
  border: 2rpx solid rgba(240, 237, 239, 0.5);
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #0050CB 0%, #0066FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 600;
  color: #FFFFFF;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 80, 203, 0.25);
}

.profile-meta {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.profile-name {
  font-size: 40rpx;
  line-height: 56rpx;
  font-weight: 600;
  color: #1B1B1D;
  margin-bottom: 4rpx;
}

.profile-sub {
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 500;
  color: #727687;
  margin-bottom: 8rpx;
}

.profile-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  letter-spacing: 0.04em;
  margin-top: 8rpx;
  width: fit-content;
}

.profile-badge.member {
  background: rgba(52, 199, 89, 0.1);
  color: #006825;
}

.profile-badge.pending {
  background: rgba(255, 149, 0, 0.1);
  color: #FF9500;
}

.profile-badge.blocked {
  background: rgba(186, 26, 26, 0.1);
  color: #BA1A1A;
}

.profile-guest-action {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  color: #0050CB;
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.arrow {
  font-size: 32rpx;
}

/* 信息网格 */
.profile-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.profile-cell {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-cell .label {
  font-size: 22rpx;
  line-height: 28rpx;
  font-weight: 500;
  color: #666666;
}

.profile-cell .value {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
  color: #1B1B1D;
}

/* 按钮 */
.secondary-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  border: 2rpx solid #BA1A1A;
  border-radius: 16rpx;
  color: #BA1A1A;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease;
}

.secondary-btn:active {
  opacity: 0.8;
}

/* 授权弹窗 */
.auth-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.auth-popup-mask.show {
  opacity: 1;
  visibility: visible;
}

.auth-popup-container {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
  overflow-y: auto;
}

.auth-popup-container.show {
  transform: translateY(0);
}

.auth-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #F0EDEF;
}

.auth-popup-title {
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 600;
  color: #1B1B1D;
}

.auth-popup-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #666666;
}

.auth-popup-body {
  padding: 32rpx;
}

.auth-form-group {
  margin-bottom: 32rpx;
}

.auth-form-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F0EDEF;
}

.auth-form-item.border-none {
  border-bottom: none;
}

.auth-form-label {
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 16rpx;
}

.auth-form-input {
  width: 100%;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
  color: #1B1B1D;
  padding: 16rpx 0;
}

.phone-auth-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.phone-auth-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.phone-auth-head .label {
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 500;
  color: #666666;
}

.quick-get-btn {
  background: #F2F7FF;
  color: #0050CB;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 500;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  border: none;
}

.phone-auth-value {
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 400;
  color: #999999;
  padding: 16rpx 24rpx;
  background: #F5F5F7;
  border-radius: 16rpx;
}

.phone-auth-value.authorized {
  color: #0050CB;
  background: rgba(0, 80, 203, 0.1);
}

.auth-agreement {
  margin: 32rpx 0;
}

.auth-checkbox-label {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.auth-checkbox {
  transform: scale(1.2);
}

.auth-agreement-text {
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 400;
  color: #666666;
}

.auth-submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #0050CB 0%, #0066FF 100%);
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 80, 203, 0.25);
  transition: opacity 0.2s ease;
  border: none;
}

.auth-submit-btn:active {
  opacity: 0.9;
}
