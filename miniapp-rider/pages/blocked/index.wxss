.state-page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff5f5 0%, var(--surface-container-low) 28%, var(--surface-container-low) 100%);
}
.state-banner {
  padding: 34rpx 32rpx;
  border-radius: 28rpx;
  color: #ffffff;
  box-shadow: 0 20rpx 48rpx rgba(220, 38, 38, 0.12);
}
.banner-red {
  background: linear-gradient(135deg, #991b1b 0%, #dc2626 62%, #fb7185 100%);
}
.state-badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  font-weight: 700;
}
.state-title {
  margin-top: 20rpx;
  font-size: 42rpx;
  line-height: 1.32;
  font-weight: 800;
}
.state-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.9);
}
.card {
  margin-top: 24rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--outline-variant);
}
.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}
.notice-card .muted {
  margin-top: 12rpx;
  line-height: 1.7;
}
.action-stack {
  margin-top: 24rpx;
  display: grid;
  gap: 16rpx;
}
