.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.form {
  background: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 70rpx;
  padding: 0 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
}

.btn-choose {
  width: 100%;
  background: #f0f0f0;
}

.preview {
  width: 100%;
  height: 400rpx;
  margin-top: 20rpx;
  border-radius: 8rpx;
}

.actions {
  margin-bottom: 20rpx;
}

.btn {
  width: 100%;
  margin-bottom: 20rpx;
  background: #1890ff;
  color: #fff;
}

.logs {
  background: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  max-height: 600rpx;
  overflow-y: scroll;
}

.logs-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #eee;
}

.logs-title {
  font-size: 28rpx;
  font-weight: bold;
}

.logs-clear {
  font-size: 24rpx;
  color: #1890ff;
}

.log-item {
  font-size: 24rpx;
  line-height: 40rpx;
  color: #666;
  margin-bottom: 10rpx;
  word-break: break-all;
}
