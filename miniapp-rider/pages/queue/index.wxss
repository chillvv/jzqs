/* pages/queue/index.wxss */

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--background, #F5F5F7);
  color: var(--on-background, #1B1B1D);
}

.scroll-area {
  flex: 1;
  height: 0;
}

/* Header */
.header-bar {
  position: sticky;
  top: 0;
  z-index: 40;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.6);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: var(--on-surface, #1B1B1D);
}

.header-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
}

.header-title {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
  letter-spacing: -0.02em;
}

.header-date {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: normal;
  color: var(--success);
  background-color: #ecfdf5;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(16, 185, 129, 0.14);
  margin-left: 16rpx;
}

.header-date-arrow {
  font-size: 18rpx;
  opacity: 0.7;
}

/* Banners */
.banner {
  padding: 16rpx 32rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 36rpx;
}

.banner-warning {
  background-color: #FFF4E5;
  color: #8C5D00;
}

.banner-error {
  background-color: var(--error-container, #FFDAD6);
  color: var(--on-error-container, #93000A);
}

.banner-icon {
  font-size: 36rpx;
  margin-top: 2rpx;
}

.banner-text {
  flex: 1;
}

/* Main Content */
.main-content {
  padding: 24rpx 28rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom) + 130rpx);
  max-width: 896rpx;
  margin: 0 auto;
}

/* Toggle & Stats */
.toggle-section {
  margin-bottom: 32rpx;
}

.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.toggle-container {
  background-color: var(--surface-container, #F1F5F9);
  border-radius: 999rpx;
  padding: 8rpx;
  display: flex;
  position: relative;
  width: 280rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(226, 232, 240, 0.8);
  box-sizing: border-box;
}

.edit-btn-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: var(--primary, #2563EB);
  background-color: var(--surface-container, #F1F5F9);
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  transition: all 0.2s;
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.header-action-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.batch-btn-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #059669;
  background-color: #ecfdf5;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  transition: all 0.2s;
  border: 1rpx solid rgba(16, 185, 129, 0.4);
}

.batch-btn-inline:active {
  opacity: 0.9;
  transform: scale(0.95);
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
  display: block;
}

.edit-text {
  font-size: 26rpx;
  font-weight: 600;
}

.header-action-disabled {
  opacity: 0.45;
}

.edit-btn-inline:active {
  opacity: 0.9;
  transform: scale(0.95);
}

.edit-icon {
  width: 32rpx;
  height: 32rpx;
  display: block;
  flex: 0 0 32rpx;
}

.toggle-bg {
  position: absolute;
  top: 8rpx;
  bottom: 8rpx;
  width: calc(50% - 8rpx);
  background-color: var(--surface, #FFFFFF);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.toggle-left {
  transform: translateX(0);
}

.toggle-right {
  transform: translateX(100%);
}

.toggle-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 36rpx;
  color: var(--on-surface-variant, #475569);
  position: relative;
  z-index: 10;
  transition: all 0.3s;
}

.toggle-btn.active {
  color: var(--primary, #2563EB);
  font-weight: 700;
}

/* Stats Bento */
.stats-bento {
  display: flex;
  background: linear-gradient(180deg, var(--surface) 0%, var(--surface-container-low) 100%);
  border-radius: 72rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05), inset 0 2rpx 4rpx rgba(255, 255, 255, 1);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
  justify-content: space-around;
  align-items: center;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.stat-value {
  font-family: 'Courier New', 'SF Mono', Monaco, monospace;
  font-size: 84rpx;
  font-weight: 900;
  letter-spacing: 0;
  color: var(--on-surface, #0F172A);
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.stat-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--surface-container-highest);
}

.stat-divider {
  width: 2rpx;
  height: 12rpx;
  background-color: rgba(203, 213, 225, 0.05);
}

.text-success {
  color: var(--success, #34C759);
}

.text-primary {
  color: var(--primary, #0050CB);
}

/* Status Filter */
.status-filter-row {
  display: flex;
  gap: 48rpx;
}

.status-filter-chip {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  background-color: var(--surface, #FFFFFF);
  color: var(--on-surface-variant, #64748B);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
  transition: all 0.25s ease;
}

.chip-active-pending {
  background-color: #FFF7ED;
  color: #C2410C;
  border-color: #EA580C;
  box-shadow: 0 6rpx 20rpx rgba(234, 88, 12, 0.3);
  font-weight: 800;
}

.chip-active-all {
  background-color: #EEF2FF;
  color: #4338CA;
  border-color: #4F46E5;
  box-shadow: 0 6rpx 20rpx rgba(79, 70, 229, 0.3);
  font-weight: 800;
}

.chip-active-delivered {
  background-color: #F0FDF4;
  color: #15803D;
  border-color: #16A34A;
  box-shadow: 0 6rpx 20rpx rgba(22, 163, 74, 0.3);
  font-weight: 800;
}

/* Orders List */
.orders-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  position: relative;
}

/* 拖拽提示 */
.drag-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, rgba(251, 146, 60, 0.15) 0%, rgba(251, 146, 60, 0.08) 100%);
  border: 2rpx dashed rgba(251, 146, 60, 0.4);
  border-radius: 20rpx;
  color: #E65100;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.drag-hint .material-symbols-outlined {
  font-size: 40rpx;
}

.batch-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.04) 100%);
  border: 1rpx solid rgba(16, 185, 129, 0.2);
  border-radius: 20rpx;
  color: #047857;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.batch-hint .hint-icon {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

.order-card {
  background-color: var(--surface, #FFFFFF);
  border-radius: 32rpx;
  padding: 36rpx 24rpx 24rpx; /* Increased top padding for absolute tag */
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.01);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
  display: block; /* Changed to block */
  position: relative;
  overflow: hidden;
  margin-bottom: 20rpx;
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.order-card-status-tag {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 20rpx;
  border-bottom-left-radius: 16rpx;
  border-top-right-radius: 20rpx;
  letter-spacing: 0.02em;
  z-index: 10;
}

.tag-pending {
  background-color: #FFF3E0;
  color: #FF9800;
}

.tag-completed {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.order-card-content {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.order-card-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  width: 100%;
}

.order-card-selected {
  border-color: rgba(16, 185, 129, 0.42);
  box-shadow: 0 10rpx 26rpx rgba(16, 185, 129, 0.12);
}

/* 待配送状态 - 蓝色背景 */
.order-card:not(.order-card-completed) {
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.04) 0%, rgba(37, 99, 235, 0.02) 100%);
  border-color: rgba(37, 99, 235, 0.15);
}

.order-card.dragging {
  opacity: 0.95;
  box-shadow: 0 40rpx 80rpx rgba(37, 99, 235, 0.35),
              0 16rpx 32rpx rgba(37, 99, 235, 0.25),
              0 8rpx 16rpx rgba(37, 99, 235, 0.2);
  border-color: rgba(37, 99, 235, 0.5);
  border-width: 2rpx;
  z-index: 9999;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.98) 100%);
}

/* 移除 dragPulse 动画以提升流畅度 */

.order-card.dragging::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.04) 0%, rgba(37, 99, 235, 0.02) 100%);
  border-radius: 20rpx;
  pointer-events: none;
}

.order-card.dragging .order-badge {
  border-color: rgba(37, 99, 235, 0.3);
  color: #1E40AF;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(37, 99, 235, 0.05) 100%);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.15);
}

/* 已完成状态 - 灰色背景 */
.order-card-completed {
  opacity: 0.85;
  box-shadow: none;
  background: var(--surface-container-low);
  border-color: rgba(226, 232, 240, 0.8);
}

.order-left {
  display: none;
}

.order-badge-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.special-tag-inline {
  font-size: 22rpx;
  font-weight: 800;
  color: #DC2626;
  background: var(--error-container);
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  line-height: 1.2;
  white-space: nowrap;
  align-self: center;
  flex-shrink: 0;
}

.batch-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  border: 2rpx solid #a7f3d0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: transparent;
  background: var(--surface);
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.batch-checkbox-selected {
  background: #059669;
  border-color: #059669;
  color: #ffffff;
}

.order-badge {
  position: relative;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 250, 252, 0.95) 100%);
  color: #1E293B;
  padding: 12rpx 18rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Courier New', 'SF Mono', Monaco, monospace;
  font-size: 72rpx;
  font-weight: 900;
  letter-spacing: -0.02em;
  flex-shrink: 0;
  min-width: 80rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 2rpx 4rpx rgba(15, 23, 42, 0.04);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);
  transform-origin: center;
  /* 不用 translateZ，避免影响父元素拖拽 */
}

.order-card:active .order-badge {
  transform: scale(0.98);
  border-color: rgba(37, 99, 235, 0.3);
}

.order-badge::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.4) 0%, 
    rgba(255, 255, 255, 0) 50%,
    rgba(0, 0, 0, 0.02) 100%);
  border-radius: 16rpx;
  pointer-events: none;
}

.badge-prefix {
  font-size: 26rpx;
  margin-right: 4rpx;
  opacity: 0.6;
  font-weight: 600;
  color: #64748B;
  font-family: 'Courier New', 'SF Mono', Monaco, monospace;
  letter-spacing: 0.02em;
}

.order-badge-completed {
  background: linear-gradient(135deg, rgba(248, 250, 252, 0.9) 0%, rgba(241, 245, 249, 0.9) 100%);
  color: #A0AEC0;
  border: 1rpx solid rgba(226, 232, 240, 0.6);
  box-shadow: 
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.6),
    0 1rpx 1rpx rgba(0, 0, 0, 0.01);
}

.order-badge-completed .badge-prefix {
  color: #CBD5E0;
  opacity: 0.4;
}

.order-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  padding-right: 90rpx; /* Prevent overlapping with the absolute top-right tag */
}

.order-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  min-height: 60rpx;
  flex-wrap: wrap;
}

.order-name {
  font-size: 36rpx;
  font-weight: 900;
  color: var(--on-surface, #0F172A);
  word-break: break-all;
  letter-spacing: -0.01em;
  min-width: 0;
}

.quantity-badge {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  color: #FFFFFF;
  font-family: 'Courier New', 'SF Mono', Monaco, monospace;
  font-size: 26rpx;
  font-weight: 800;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.4),
              0 2rpx 6rpx rgba(255, 107, 53, 0.3);
  letter-spacing: 0.02em;
  animation: quantityPulse 2s ease-in-out infinite;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

@keyframes quantityPulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.4),
                0 2rpx 6rpx rgba(255, 107, 53, 0.3);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 6rpx 16rpx rgba(255, 107, 53, 0.5),
                0 3rpx 8rpx rgba(255, 107, 53, 0.4);
  }
}

.order-name-completed {
  color: var(--on-surface-variant, #475569);
  text-decoration: line-through;
  text-decoration-color: var(--outline-variant, #E2E8F0);
}

.order-address {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--outline);
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  min-width: 0;
  background: rgba(248, 250, 252, 0.7);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

.address-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.address-text-content {
  flex: 1;
  min-width: 0;
  white-space: normal;
  color: #64748B;
  word-break: break-all;
  line-height: 1.5;
}

.building-info-text {
  color: var(--brand-color);
  font-weight: 900;
  margin-right: 8rpx;
}

.no-address {
  color: var(--outline, #94A3B8);
  font-style: italic;
}

.order-address-completed {
  color: var(--outline, #C2C6D8);
}

.order-address-completed .icon-location {
  color: var(--outline, #C2C6D8);
}

.order-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: auto;
}

.status-tag {
  font-size: 22rpx;
  font-weight: 700;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  letter-spacing: 0.02em;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tag-pending {
  background-color: #FFF3E0;
  color: #FF9800;
}

.tag-completed {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.drag-handle {
  display: none;
  color: var(--outline, #94A3B8);
  padding: 12rpx;
  position: relative;
  background: rgba(251, 146, 60, 0.1);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.drag-handle .material-symbols-outlined {
  font-size: 40rpx;
}

.drag-handle::after {
  content: '长按拖动';
  position: absolute;
  top: -56rpx;
  right: 0;
  background: rgba(251, 146, 60, 0.95);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  box-shadow: 0 8rpx 24rpx rgba(251, 146, 60, 0.4);
}

/* Edit Mode */
.edit-mode .drag-handle {
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-mode .order-card {
  will-change: transform;
}

.edit-mode .order-card:active .drag-handle {
  background: rgba(251, 146, 60, 0.25);
  transform: scale(0.95);
}

.edit-mode .order-card:active .drag-handle::after {
  opacity: 1;
}

.edit-mode .status-tag {
  display: none;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  opacity: 0.6;
}

.empty-icon {
  margin-bottom: 24rpx;
  color: var(--on-surface-variant, #424656);
}

.empty-text {
  font-size: 28rpx;
  color: var(--on-surface-variant, #424656);
}

.batch-action-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(130rpx + env(safe-area-inset-bottom) + 24rpx);
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
  border-radius: 28rpx;
  padding: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 60;
}

.batch-action-safe-spacer {
  height: calc(180rpx + env(safe-area-inset-bottom) + 130rpx);
}

.batch-action-summary {
  flex: 1;
  min-width: 0;
}

.batch-action-count {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--on-surface);
}

.batch-action-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.batch-submit-btn {
  margin: 0;
  min-width: 260rpx;
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: none;
  background: #059669;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(16, 185, 129, 0.24);
}

.date-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.32);
  z-index: 1000;
}

.date-picker-sheet {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(130rpx + env(safe-area-inset-bottom) + 24rpx);
  background: var(--surface);
  border-radius: 28rpx;
  padding: 28rpx;
  max-height: calc(100vh - 240rpx - env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.18);
  z-index: 1001;
}

.date-picker-sheet__header {
  margin-bottom: 20rpx;
}

.date-picker-sheet__title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.date-picker-sheet__subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.date-picker-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.date-picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
  background: var(--surface-container-low);
  border: 2rpx solid transparent;
}

.date-picker-option--active {
  background: #ecfdf5;
  border-color: rgba(16, 185, 129, 0.22);
}

.date-picker-option__label {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.date-picker-option__value {
  font-size: 26rpx;
  color: var(--success);
}
