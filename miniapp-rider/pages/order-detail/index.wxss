/* pages/order-detail/index.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--surface-container-low, #f8fafc);
  color: var(--on-background, #0f172a);
  display: flex;
  flex-direction: column;
}

.order-detail-nav-right {
  min-width: 120rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  flex-shrink: 0;
}

.status-badge {
  background-color: var(--tertiary-container, #d1fae5);
  color: var(--tertiary, #10b981);
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-weight: 700;
  margin-left: 16rpx;
}

.status-badge-pending {
  background-color: var(--primary-container, #eff6ff);
  color: var(--primary, #2563eb);
}

/* Empty States */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  opacity: 0.6;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  color: var(--on-surface-variant, #424656);
}

.empty-text {
  font-size: 28rpx;
  color: var(--on-surface-variant, #424656);
}

/* Main Content */
.main-content {
  padding: 24rpx;
  max-width: 896rpx;
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Reusable Detail Card (Pro Max) */
.detail-card {
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.03);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--on-surface-variant, #475569);
}

/* Address & Contact Card */
.address-card {
  padding-bottom: 24rpx;
}

.inline-remarks {
  background: var(--surface-container, #f1f5f9);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.inline-remark-item {
  font-size: 26rpx;
  line-height: 1.5;
}

.inline-remark-label {
  font-weight: 700;
}

.inline-remark-value {
  color: var(--on-surface, #0f172a);
}

.address-text {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.6;
  color: var(--on-surface, #0f172a);
  margin-bottom: 24rpx;
  word-break: break-all;
}

.address-building {
  font-weight: 800;
  font-size: 40rpx;
  color: var(--primary, #2563eb);
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -0.01em;
}

.address-text:active {
  opacity: 0.7;
}

.reference-entry-row {
  margin-bottom: 20rpx;
}

.reference-summary-card {
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 1rpx solid rgba(226, 232, 240, 0.8);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.reference-summary-copy {
  flex: 1;
  min-width: 0;
}

.reference-summary-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #475569;
}

.reference-summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #0f172a;
  word-break: break-all;
}

.reference-summary-empty {
  color: #64748b;
}

.reference-summary-action {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 700;
  color: #047857;
  background: #d1fae5;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
}

.customer-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(226, 232, 240, 0.6);
  gap: 16rpx;
}

.customer-details {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.customer-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--on-surface, #0f172a);
  word-break: break-all;
}

.customer-phone {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--on-surface-variant, #475569);
  word-break: break-all;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  flex-direction: row;
  font-family:
    -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue",
    sans-serif;
  letter-spacing: 0.02em;
}

.action-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.phone-btn {
  background-color: #f1f5f9;
  color: #334155;
  border: none;
}

.nav-btn {
  background-color: #eff6ff;
  color: #2563eb;
  border: none;
}

.action-btn-ghost {
  background-color: #f5f3ff;
  color: #6d28d9;
  border: none;
  padding: 14rpx 28rpx;
}

.btn-icon {
  font-size: 32rpx;
  font-variation-settings: "FILL" 1;
}

.btn-text {
  font-size: 26rpx;
  font-weight: 600;
}

.phone-btn .btn-icon {
  color: #64748b;
}

.nav-btn .btn-icon {
  color: #3b82f6;
}

/* Proof Section */
.proof-section {
  padding-bottom: 24rpx;
}

.proof-tip {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--on-surface-variant, #475569);
  margin-bottom: 24rpx;
}

.detail-note-card {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  color: var(--on-surface-variant, #475569);
  font-size: 24rpx;
  line-height: 1.7;
}

.detail-note-card--actions {
  background: #ffffff;
  padding: 28rpx;
}

.detail-note-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--on-surface, #0f172a);
}

.detail-note-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--on-surface-variant, #475569);
  word-break: break-all;
}

.detail-note-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.photo-upload-area {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.photo-upload-btn {
  width: 100%;
  height: 240rpx;
  background-color: var(--surface-container-low, #f8fafc);
  border-radius: 24rpx;
  border: 4rpx dashed #cbd5e1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #64748b;
  transition: all 0.2s;
}

.photo-upload-btn:active {
  background-color: var(--surface-container, #f1f5f9);
  border-color: #94a3b8;
}

.upload-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
  opacity: 0.6;
}

.photo-upload-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #475569;
}

.photo-preview {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.preview-img {
  width: 100%;
  height: 100%;
}

.photo-delete-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(15, 23, 42, 0.75);
  backdrop-filter: blur(8px);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
}

.photo-delete-btn .icon-sm {
  font-size: 32rpx;
}

.rider-note-area {
  background-color: var(--surface-container, #f1f5f9);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.rider-note-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: var(--on-surface, #0f172a);
  line-height: 1.5;
}

/* Bottom Action Bar */
.bottom-spacer {
  height: 160rpx;
}

.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(15, 23, 42, 0.04);
  border-top: 1rpx solid rgba(226, 232, 240, 0.6);
  box-sizing: border-box;
  z-index: 100;
}

.action-bar-buttons {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.cancel-btn {
  flex: 0 0 auto;
  min-width: 160rpx;
  height: 96rpx;
  background-color: #f1f5f9;
  color: #475569;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  border: none;
  padding: 0;
  margin: 0;
}

.cancel-btn:active {
  transform: scale(0.96);
  background-color: #e2e8f0;
}

.submit-btn {
  flex: 1;
  height: 96rpx;
  background-color: #2563eb;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 6rpx 20rpx rgba(37, 99, 235, 0.25);
  padding: 0;
  margin: 0;
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(37, 99, 235, 0.2);
  opacity: 0.9;
}

.submit-btn.disabled {
  opacity: 1;
  background-color: #e2e8f0;
  color: #94a3b8;
  box-shadow: none;
}

.delivered-status-btn {
  width: 100%;
  height: 96rpx;
  background-color: #ecfdf5;
  color: #059669;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: none;
}
/* 已送达回执查看区域 */
.delivered-receipt-view {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.submitted-photo {
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.receipt-img {
  width: 100%;
  height: 400rpx;
}

.no-photo-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--on-surface-variant, #94a3b8);
  gap: 16rpx;
}

.no-photo-hint .material-symbols-outlined {
  font-size: 96rpx;
  opacity: 0.5;
}

.submitted-note {
  background-color: var(--surface-container, #f1f5f9);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.note-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--on-surface-variant, #475569);
  display: block;
  margin-bottom: 8rpx;
}

.note-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--on-surface, #0f172a);
  word-break: break-all;
}

/* 回执操作按钮 */
.receipt-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.action-btn-secondary,
.action-btn-danger {
  flex: 1;
  height: 80rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  border: none;
  padding: 0;
  margin: 0;
}

.action-btn-secondary {
  background-color: #eff6ff;
  color: #2563eb;
}

.action-btn-secondary:active {
  transform: scale(0.96);
  background-color: #dbeafe;
}

.action-btn-danger {
  background-color: #fef2f2;
  color: #dc2626;
}

.action-btn-danger:active {
  transform: scale(0.96);
  background-color: #fee2e2;
}

.action-btn-secondary .material-symbols-outlined,
.action-btn-danger .material-symbols-outlined {
  font-size: 32rpx;
}

.reference-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.42);
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s ease;
  z-index: 120;
}

.reference-sheet-mask.show {
  opacity: 1;
  visibility: visible;
}

.reference-sheet {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 24rpx 64rpx rgba(15, 23, 42, 0.16);
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  transform: translateY(120%);
  transition: transform 0.22s ease;
  z-index: 130;
  overflow: hidden;
}

.reference-sheet.show {
  transform: translateY(0);
}

.reference-sheet-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx 28rpx 20rpx;
}

.reference-sheet-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}

.reference-sheet-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}

.reference-sheet-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  flex-shrink: 0;
}

.reference-sheet-body {
  padding: 0 28rpx 24rpx;
}

.reference-sheet-preview {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  background: #f8fafc;
}

.reference-sheet-image {
  width: 100%;
  height: 440rpx;
  display: block;
}

.reference-sheet-preview-hint {
  position: absolute;
  left: 24rpx;
  bottom: 24rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.64);
  color: #ffffff;
  font-size: 22rpx;
}

.reference-sheet-empty {
  padding: 56rpx 32rpx;
  border-radius: 28rpx;
  background: #f8fafc;
  border: 1rpx dashed rgba(148, 163, 184, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.reference-sheet-empty-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.7;
}

.reference-sheet-empty-title {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.reference-sheet-empty-copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.reference-sheet-footer {
  padding: 0 28rpx calc(28rpx + env(safe-area-inset-bottom));
}

.reference-sheet-primary {
  width: 100%;
  height: 88rpx;
  margin: 0;
  border: none;
  border-radius: 999rpx;
  background: #059669;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(16, 185, 129, 0.22);
}
