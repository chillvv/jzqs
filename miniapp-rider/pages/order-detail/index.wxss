/* pages/order-detail/index.wxss */

.page-container {
  min-height: 100vh;
  background-color: var(--surface-container-low, #F8FAFC);
  color: var(--on-background, #0F172A);
  display: flex;
  flex-direction: column;
}

/* Header */
.header-bar {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.6);
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: var(--on-surface-variant, #475569);
  transition: background-color 0.2s;
}

.back-btn:active {
  background-color: var(--surface-container, #F1F5F9);
}

.header-title {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--on-surface, #0F172A);
}

.status-badge {
  background-color: var(--tertiary-container, #D1FAE5);
  color: var(--tertiary, #10B981);
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-weight: 700;
  margin-left: 16rpx;
}

.status-badge-pending {
  background-color: var(--primary-container, #EFF6FF);
  color: var(--primary, #2563EB);
}

/* Empty States */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  opacity: 0.6;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  color: var(--on-surface-variant, #424656);
}

.empty-text {
  font-size: 28rpx;
  color: var(--on-surface-variant, #424656);
}

/* Main Content */
.main-content {
  padding: 24rpx;
  max-width: 896rpx;
  margin: 0 auto;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Reusable Detail Card (Pro Max) */
.detail-card {
  background-color: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.03);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--on-surface-variant, #475569);
}

/* Address & Contact Card */
.address-card {
  padding-bottom: 24rpx;
}

.address-text {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.6;
  color: var(--on-surface, #0F172A);
  margin-bottom: 24rpx;
}

.address-building {
  font-weight: 800;
  font-size: 40rpx;
  color: var(--primary, #2563EB);
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: -0.01em;
}

.address-text:active {
  opacity: 0.7;
}

.customer-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(226, 232, 240, 0.6);
}

.customer-details {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.customer-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--on-surface, #0F172A);
}

.customer-phone {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--on-surface-variant, #475569);
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  border-radius: 8rpx;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  flex-direction: row;
  position: relative;
  overflow: hidden;
  border: 1rpx solid transparent;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', sans-serif;
  letter-spacing: -0.01em;
}

.action-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.1) 0%, 
    rgba(255, 255, 255, 0) 50%,
    rgba(0, 0, 0, 0.02) 100%);
  pointer-events: none;
  border-radius: 7rpx;
  transition: opacity 0.2s ease;
}

.action-btn::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, 
    rgba(255, 255, 255, 0.2) 0%, 
    rgba(255, 255, 255, 0.1) 50%,
    rgba(0, 0, 0, 0.01) 100%);
  pointer-events: none;
  border-radius: 7rpx;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.action-btn:active {
  transform: translateY(1rpx);
}

.action-btn:active::after {
  opacity: 1;
}

.phone-btn {
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  color: #4A5568;
  border: 1rpx solid #E2E8F0;
  box-shadow: 
    0 2rpx 4rpx rgba(0, 0, 0, 0.02),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

.phone-btn:active {
  background: linear-gradient(135deg, #F1F5F9 0%, #E2E8F0 100%);
}

.nav-btn {
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.08) 0%, rgba(59, 130, 246, 0.12) 100%);
  color: #2563EB;
  border: 1rpx solid rgba(37, 99, 235, 0.2);
  box-shadow: 
    0 2rpx 4rpx rgba(37, 99, 235, 0.05),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.6);
}

.nav-btn:active {
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.12) 0%, rgba(59, 130, 246, 0.16) 100%);
}

.btn-icon {
  font-size: 32rpx;
  font-variation-settings: 'FILL' 0;
}

.btn-text {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.phone-btn .btn-icon {
  color: #718096;
}

.nav-btn .btn-icon {
  color: #2563EB;
}

/* Remarks Grid */
.remarks-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.remark-card {
  padding: 24rpx;
  border-radius: 24rpx;
}

.user-remark {
  background-color: var(--primary-container, #EFF6FF);
  border: 1rpx solid rgba(37, 99, 235, 0.1);
  box-shadow: none;
}

.merchant-remark {
  background-color: var(--error-container, #FEE2E2);
  border: 1rpx solid rgba(239, 68, 68, 0.1);
  box-shadow: none;
}

.remark-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.remark-title {
  font-size: 26rpx;
  font-weight: 700;
}

.remark-text {
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 500;
  color: var(--on-surface, #0F172A);
}

.text-warning {
  color: #F59E0B;
}

/* Proof Section */
.proof-section {
  padding-bottom: 24rpx;
}

.proof-subtitle {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--on-surface-variant, #475569);
  margin-bottom: 24rpx;
  margin-top: -16rpx;
}

.detail-note-card {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #F8FAFC;
  color: var(--on-surface-variant, #475569);
  font-size: 24rpx;
  line-height: 1.7;
}

.detail-note-card--actions {
  background: #FFFFFF;
  padding: 28rpx;
}

.detail-note-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--on-surface, #0F172A);
}

.detail-note-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--on-surface-variant, #475569);
}

.detail-note-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.photo-upload-area {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.photo-upload-btn {
  width: 160rpx;
  height: 160rpx;
  background-color: var(--surface-container-low, #F8FAFC);
  border-radius: 24rpx;
  border: 2rpx dashed #CBD5E1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: #94A3B8;
  transition: all 0.2s;
}

.photo-upload-btn:active {
  background-color: var(--surface-container, #F1F5F9);
}

.photo-upload-text {
  font-size: 24rpx;
  font-weight: 600;
}

.photo-preview {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.preview-img {
  width: 100%;
  height: 100%;
}

.photo-delete-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(4px);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
}

.rider-note-area {
  background-color: var(--surface-container, #F1F5F9);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.rider-note-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: var(--on-surface, #0F172A);
  line-height: 1.5;
}

/* Bottom Action Bar */
.bottom-spacer {
  height: 160rpx;
}

.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(15, 23, 42, 0.04);
  border-top: 1rpx solid rgba(226, 232, 240, 0.6);
  box-sizing: border-box;
  z-index: 100;
}

.action-bar-buttons {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.cancel-btn {
  flex: 0 0 auto;
  min-width: 160rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  color: #64748B;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
  padding: 0;
  margin: 0;
}

.cancel-btn:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #F1F5F9 0%, #E2E8F0 100%);
}

.submit-btn {
  flex: 1;
  height: 96rpx;
  background: linear-gradient(135deg, #2563EB 0%, #3B82F6 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
  padding: 0;
  margin: 0;
  border: none;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.2);
}

.submit-btn.disabled {
  opacity: 1;
  background: #E0E0E0;
  color: #9E9E9E;
  box-shadow: none;
}

.delivered-status-btn {
  width: 100%;
  height: 96rpx;
  background-color: var(--surface-container-low, #F8FAFC);
  color: var(--tertiary, #10B981);
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 1rpx solid rgba(16, 185, 129, 0.2);
}
/* 已送达回执查看区域 */
.delivered-receipt-view {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.submitted-photo {
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.receipt-img {
  width: 100%;
  height: 400rpx;
}

.no-photo-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--on-surface-variant, #94A3B8);
  gap: 16rpx;
}

.no-photo-hint .material-symbols-outlined {
  font-size: 96rpx;
  opacity: 0.5;
}

.submitted-note {
  background-color: var(--surface-container, #F1F5F9);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.note-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--on-surface-variant, #475569);
  display: block;
  margin-bottom: 8rpx;
}

.note-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--on-surface, #0F172A);
}

/* 回执操作按钮 */
.receipt-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.action-btn-secondary,
.action-btn-danger {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s;
  border: none;
  padding: 0;
  margin: 0;
}

.action-btn-secondary {
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  color: #2563EB;
  border: 1rpx solid rgba(37, 99, 235, 0.2);
}

.action-btn-secondary:active {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.action-btn-danger {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  color: #DC2626;
  border: 1rpx solid rgba(220, 38, 38, 0.2);
}

.action-btn-danger:active {
  background: linear-gradient(135deg, #FECACA 0%, #FCA5A5 100%);
}

.action-btn-secondary .material-symbols-outlined,
.action-btn-danger .material-symbols-outlined {
  font-size: 32rpx;
}
